{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:netlab:topology",
  "description": "Example topology model inspired by network lab tools: nodes, links, and services that reference node names.",
  "x-yang": {
    "module": "netlab-topology",
    "yang-version": "1.1",
    "namespace": "urn:netlab:topology",
    "prefix": "nt",
    "organization": "xYang skill example",
    "contact": "https://github.com/exergy-connect/xYang"
  },
  "type": "object",
  "properties": {
    "topology": {
      "type": "object",
      "description": "Single-lab topology (devices and cables).",
      "x-yang": {
        "type": "container"
      },
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "role": {
                "type": "string",
                "description": "e.g. router, switch, host.",
                "x-yang": {
                  "type": "leaf"
                }
              }
            },
            "additionalProperties": false
          },
          "description": "Router, switch, or end host in the lab.",
          "x-yang": {
            "type": "list",
            "key": "name"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "source": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leafref",
                  "path": "/topology/nodes/name",
                  "require-instance": true
                }
              },
              "target": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leafref",
                  "path": "/topology/nodes/name",
                  "require-instance": true
                }
              }
            },
            "additionalProperties": false
          },
          "description": "Layer-3 or layer-2 edge between two nodes.",
          "x-yang": {
            "type": "list",
            "key": "name",
            "must": [
              {
                "must": "source != target",
                "error-message": "A link cannot connect a node to itself.",
                "description": "Referential integrity: distinct endpoints."
              }
            ]
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "",
                "x-yang": {
                  "type": "leaf"
                }
              },
              "runs-on": {
                "type": "string",
                "description": "Absolute path to a node in this topology (e.g. /topology/nodes[name='r1']).",
                "x-yang": {
                  "type": "instance-identifier",
                  "require-instance": true
                }
              }
            },
            "additionalProperties": false
          },
          "description": "Service or workload pinned to a node via instance-identifier (absolute path).",
          "x-yang": {
            "type": "list",
            "key": "name"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
