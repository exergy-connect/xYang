      leaf encoding-sont {
        type enumeration {
          enum "non-encoding-sont" {
            value 0;
            description
              "Not support SONT.";
          }
          enum "encoding-sont" {
            value 1;
            description
              "Support SONT.";
          }
        }
        config false;
        description
          "Indicate encoding mechanism SONT support or not..";
      }
      leaf dbrmin {
        type uint32;
        units "100 Mbit/s";
        config false;
        description
          "Indicate Minimum bit rate.";
      }
      leaf support-len-smf {
        type uint32;
        config false;
        description
          "Indicate the link length that is supported by the transceiver with the applicable standards
           using Single-mode Fiber.";
      }
      leaf wavelength {
        type uint32;
        config false;
        description
          "The laser wavelength.";
      }
      leaf ccext {
        type uint32;
        config false;
        description
          "Indicate the CC_EXT.";
      }
      leaf detector {
        type enumeration {
          enum "non-detector" {
            value 0;
            description
              "Detector is disable.";
          }
          enum "detector" {
            value 1;
            description
              "Detector is enable.";
          }
          enum "invalid" {
            value -1;
            description
              "Invalid value.";
          }
        }
        config false;
        description
          "Indicates the detector switch.";
      }
    }
  }
}
