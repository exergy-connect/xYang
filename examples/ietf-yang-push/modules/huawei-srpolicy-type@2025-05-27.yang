submodule huawei-srpolicy-type {
  belongs-to huawei-srpolicy {
    prefix srpolicy;
  }

  import ietf-inet-types {
    prefix inet;
  }

  organization
    "Huawei Technologies Co., Ltd.";
  contact
    "Huawei Industrial Base
     Bantian, Longgang
     Shenzhen 518129
     People's Republic of China
     Website: http://www.huawei.com
     Email: support@huawei.com";
  description
    "Segment-routing type defined file.";

  revision 2025-05-27 {
    description
      "Added dual-fed-type, and group-create-type.";
    reference
      "Huawei private.";
  }
  revision 2024-10-28 {
    description
      "Added path-mtu-detect-type, group-match-type, service-class-type, binding-sid-endpoint-behavior-type, map-match-type, address-family-display-type, and path-mtu-detected-state-type.";
    reference
      "Huawei private.";
  }
  revision 2024-09-01 {
    description
      "Added xsid-encapsulation-type.";
    reference
      "Huawei private.";
  }
  revision 2023-11-20 {
    description
      "The enumerated value no-flavor is deleted from compress-flavor-type.";
    reference
      "Huawei private.";
  }
  revision 2023-03-08 {
    description
      "Add the enumerated values of bfd-bypass-type and policy-bfd-bypass-type.";
    reference
      "Huawei private.";
  }
  revision 2023-02-28 {
    description
      "Add shortcut-mode.";
    reference
      "Huawei private.";
  }
  revision 2023-02-25 {
    description
      "Add sid-selection-type.";
    reference
      "Huawei private.";
  }
  revision 2022-11-08 {
    description
      "Add the enumerated value of compress-flavor-type.";
    reference
      "Huawei private.";
  }
  revision 2022-10-24 {
    description
      "Add policy-compute-type.";
    reference
      "Huawei private.";
  }
  revision 2022-10-12 {
    description
      "Add metric-type, hop-type, constraint-type, affinity-include-type, global-compute-type, delegate-protocol-type.";
    reference
      "Huawei private.";
  }
  revision 2022-04-15 {
    description
      "Add ifit-measure-mode-type.";
    reference
      "Huawei private.";
  }
  revision 2022-03-08 {
    description
      "Increate the function to specify the return tunnel of seamless BFD packets based on a specified binding SID.";
    reference
      "Huawei private.";
  }
  revision 2020-09-14 {
    description
      "Increate the BFD bypass type and policy BFD bypass type.";
    reference
      "Huawei private.";
  }
  revision 2020-06-28 {
    description
      "Modify description information.";
    reference
      "Huawei private.";
