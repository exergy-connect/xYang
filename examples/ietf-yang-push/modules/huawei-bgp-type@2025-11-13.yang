    reference
      "Huawei private.";
  }
  revision 2023-11-07 {
    description
      "Add object-type and attr-type. Add an enumerated value for object-type and attr-type respectively.";
    reference
      "Huawei private.";
  }
  revision 2023-09-25 {
    description
      "Modify the grouping of slow-peer-type.";
    reference
      "Huawei private.";
  }
  revision 2023-09-05 {
    description
      "Modify peer-establish-mode.";
    reference
      "Huawei private.";
  }
  revision 2023-07-28 {
    description
      "Add direct-route-type.";
    reference
      "Huawei private.";
  }
  revision 2023-05-09 {
    description
      "Add enable type.";
    reference
      "Huawei private.";
  }
  revision 2023-03-02 {
    description
      "Modify zero-length-attribute-id type.";
    reference
      "Huawei private.";
  }
  revision 2023-01-31 {
    description
      "Add labeluni-apply-label-type.";
    reference
      "Huawei private.";
  }
  revision 2023-01-11 {
    description
      "Add IPv4 multicast import-rib type.";
    reference
      "Huawei private.";
  }
  revision 2022-11-03 {
    description
      "Add zero-value-attribute-id and zero-length-attribute-id.";
    reference
      "Huawei private.";
  }
  revision 2022-09-06 {
    description
      "Add op-route for IPv6-import-route-protocol-type.";
    reference
      "Huawei private.";
  }
  revision 2022-06-10 {
    description
      "Add IPv4-address-family-priority-type and IPv6-address-family-priority-type. Add advertise-community-gshut-type.";
    reference
      "Huawei private.";
  }
  revision 2022-01-30 {
    description
      "Add multiple instance nodes. Add multiple instance node type.";
    reference
      "Huawei private.";
  }
  revision 2021-08-11 {
    description
      "Modify description of path-attr-treat node.";
    reference
      "Huawei private.";
  }
  revision 2019-03-22 {
    description
      "Initial revision.";
    reference
