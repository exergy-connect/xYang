submodule huawei-bgp-type {
  yang-version 1;
  belongs-to huawei-bgp {
    prefix bgp;
  }

  organization
    "Huawei Technologies Co., Ltd.";
  contact
    "Huawei Industrial Base
     Bantian, Longgang
     Shenzhen 518129
     People's Republic of China
     Website: http://www.huawei.com
     Email: support@huawei.com";
  description
    "Defines type definitions associated with the huawei-bgp modules.";

  revision 2025-11-13 {
    description
      "Add enum active to typedef bgp-advertise-route-mode. Add zero-value-peer-attribute. Add typedef detail-trim-set-type. Add typedef alarm-route-type.";
    reference
      "Huawei private.";
  }
  revision 2025-10-10 {
    description
      "Add enum BGP-SPF and BGP-TVR protocol.";
    reference
      "Huawei private.";
  }
  revision 2025-09-11 {
    description
      "Add enum active to typedef bgp-advertise-route-mode. Add zero-value-peer-attribute. Add typedef detail-trim-set-type. Add typedef alarm-route-type.";
    reference
      "Huawei private.";
  }
  revision 2024-04-30 {
    description
      "Add path-sub-attr-action-type type. Add attribute-id-for-sub type.";
    reference
      "Huawei private.";
  }
  revision 2024-03-13 {
