              \t   words also allow user-defined string enclosed by double quotation
              \t   marks and optional content enclosed by brackets.
              \t   System-defined separators:
              \t   ' ', '.', ':', '/', '-', '%', ',', ';', '#', '!'
              \t  ";
      }
    }
    container xpon {
      description
        "format-string for xpon access.";
      leaf info {
        type string {
          length "0..255";
        }
        description
          "Info format string. The string is the combination of
              \t   system-defined key words and separators as following:
             \t   System-defined key words:
              \t   anid, anip, eth, accesstype, linetype, xpon, chassis, rack, frame,
              \t   slot, logicalslot, subslot, port, port+1, cvlanid, vlanid, priority,
              \t   plabel, splabel, sprlabel, sprlabelhex, bslot, bsubslot, bport,
              \t   bvlanid, bporttype, 8021p, xpi, xci, axpi, axci, gem-index, gemport,
              \t   uprate, dnrate, ontid, ontid+1, ontportid, ontporttype, ontlabel,
              \t   onuid, onutag, SN, SN_ASCII, loid, 0002, up, down, ge, docsis,
              \t   plain text, optional keyword, onusnmac, svlanid, SN_HYBRID, pwd. The key
              \t   words also allow user-defined string enclosed by double quotation
              \t   marks and optional content enclosed by brackets.
              \t   System-defined separators:
              \t   ' ', '.', ':', '/', '-', '%', ',', ';', '#', '!'
              \t  ";
      }
    }
