module huawei-bb-raio-profiles {
  namespace "urn:huawei:yang:huawei-bb-raio-profiles";
  prefix hw-bb-raio-prof;

  import huawei-bb-vlan {
    prefix huawei-vlan;
  }

  organization
    "Huawei Technologies Co., Ltd.";
  contact
    "Huawei Industrial Base
     Bantian, Longgang
     Shenzhen 518129
     People's Republic of China
     Website: http://www.huawei.com
     Email: support@huawei.com";
  description
    "This module contains a collection of yang definitions for
     configuring the RAIO profile for the broadband services.";

  revision 2020-11-10 {
    description
      "Modify the description of container xpon";
    reference
      "";
  }
  revision 2020-05-20 {
    description
      "Import huawei-bb-vlan.";
    reference
      "";
  }
  revision 2019-10-08 {
    description
      "Modify the description of leaf cid.
       Modify the description of leaf rid.
       Modify the description of leaf info";
    reference
      "";
  }
  revision 2019-08-30 {
    description
      "Modify the description of leaf cid.
       Modify the description of leaf rid.
       Modify the description of container bb-raio-profiles";
    reference
      "";
  }
  revision 2019-08-06 {
    description
      "Modify the name of leaf not-config to none.
       Modify the name of enum xdslPortRate to xdsl-port-rate";
    reference
      "";
  }
  revision 2018-08-23 {
    description
      "Initial revision.";
    reference
      "";
  }

  typedef raio-mode-options {
    type enumeration {
      enum "common" {
        value 1;
        description
          "common mode:
                      1. ETH
                 \t\t    CID:anid eth frame/slot/subslot/port:vlanid
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t 3. docsis
                 \t\t    CID:anid docsis frame/slot/subslot/port
                 \t\t\tRID:splabel
                 \t\t";
      }
      enum "xdsl-port-rate" {
        value 2;
        description
          "xdslPort mode for MA5600T, not supported on MA5800:
                      1. ETH/EoC
                 \t\t    CID:anid eth frame/slot/subslot/port:vlanid
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t 3. ATM
                 \t\t    CID:anid atm frame/slot/subslot/port:vpi.vci%up:uprate down:dnrate
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "cntel" {
        value 3;
        description
          "cntel mode:
                      1. ETH
                 \t\t    CID:bporttype bslot/bsubslot/bport:xpi.xci anid/rack/frame/slot/subslot/port:axpi.axci
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "ti" {
        value 4;
        description
          "ti mode:
                      1. ETH
                 \t\t    CID:anid eth frame/slot02/subslot/port03:vlanid04
                 \t\t\tRID:plabel
                 \t\t 2. XPON
                 \t\t    CID:anid pon frame/slot02/port/ontid03:vlanid04
                 \t\t\tRID:ontlabel
                 \t\t";
      }
      enum "neuf" {
        value 5;
        description
          "neuf mode:
                      1. ETH
                 \t\t    CID:anid-0002-vlanid04-GE
                 \t\t\tRID:anid-0002-vlanid04-GE
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.ontportid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "port-userlabel" {
        value 6;
        description
          "port-userlabel mode:
                      1. ETH
                 \t\t    CID:anid eth slot02/port:vlanid
                 \t\t\tRID:plabel
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID:plabel
                 \t\t";
      }
      enum "bt" {
        value 7;
        description
          "bt mode, not supported on MA5800";
      }
      enum "service-port-userlabel" {
        value 8;
        description
          "service-port-userlabel mode:
                      1. ETH
                 \t\t    CID:anid eth slot02/port:vlanid
                 \t\t\tRID:plabel
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID:splabel
                 \t\t";
      }
      enum "dslforum-default" {
        value 9;
        description
          "dslforum-default mode:
                      1. ETH
                 \t\t    CID:anid eth slot/port:vlanid
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "ft" {
        value 10;
        description
          "ft mode:
                      CID:splabel
                 \t\t RID:remote description
                 \t\t";
      }
      enum "brt" {
        value 11;
        description
          "brt mode:
                      1. ETH
                 \t\t    CID:anid.slot.port
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID:anid xpon frame/slot/subslot/port:ontid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "user-defined" {
        value 12;
        description
          "user-defined mode, cid and rid format refer to format-string
                 \t\t";
      }
      enum "cntel-xpon" {
        value 13;
        description
          "cntel-xpon mode:
                      1. ETH
                 \t\t    CID:bporttype bslot/bsubslot/bport:xpi.xci anid/rack/frame/slot/subslot/port:axpi.axci
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID(FTTH):bporttype bslot/bsubslot/bport:svlanid.cvlanid anid/rack/frame/slot/subslot/port/onuid accesstype
                 \t\t\tCID(FTTB):bporttype bslot/bsubslot/bport:svlanid.cvlanid anid/rack/frame/slot/subslot/port/onuid onuslot/onusubslot/onuportid:onuporttype/portxpi.portxci accesstype
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "tm" {
        value 14;
        description
          "tm mode:
                      1. ETH
                 \t\t    CID is empty
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID:anid frame/slot/subslot/port/ontid.ontportid.gemport.vlanid
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "bbf" {
        value 15;
        description
          "bbf mode:
                      1. ETH
                 \t\t    CID:anid eth slot.port[:vlanid]
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID(ATM):anid atm slot/port/onuid/slot/port:vpi.vci
                 \t\t\tCID(ETH):anid eth slot/port/onuid/slot/port[:vlanid]
                 \t\t\tRID:ontlabel
                 \t\t";
      }
      enum "vnpt" {
        value 16;
        description
          "vnpt mode:
                      1. ETH
                 \t\t    CID:anid eth frame/frame/frame/frame/slot/port: axci.vlanid
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID(ATM):anid atm frame/slot/port/onuid/slot/port:vpi.vci
                 \t\t\tCID(ETH):anid eth frame/slot/port/onuid/slot/port: axci .vlanid
                 \t\t\tRID is empty
                 \t\t";
      }
      enum "true" {
        value 17;
        description
          "true mode:
                      1. ETH
                 \t\t    CID is empty
                 \t\t\tRID is empty
                 \t\t 2. XPON
                 \t\t    CID is empty
                 \t\t\tRID is empty
                 \t\t 3. docsis
                 \t\t    CID:xifindex
                 \t\t\tRID:splabel
                 \t\t";
      }
      enum "skb" {
        value 18;
        description
          "skb mode: not supported on MA5800";
      }
    }
    description
      "Configuration of raio mode options.";
  }

  typedef sub-option-switch {
    type bits {
      bit sub-option81 {
