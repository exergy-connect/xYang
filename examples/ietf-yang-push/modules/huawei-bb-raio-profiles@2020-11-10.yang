  container bb-raio-profiles {
    description
      "configuration of raio profile for dhcp-option82, dhcpv6-option, pitp-pmode and pitp-vmode.";
    list raio-profile {
      key "name";
      description
        "The list of raio-profile";
      leaf name {
        type string {
          length "1..32";
        }
        description
          "Specifies the raio profile";
      }
      leaf access-node-id {
        type string {
          length "0..50";
        }
        description
          "Indicate the ANID, empty string indicates undo operation. When raio-mode is bbf, blank space is not allowed in the string.";
      }
      choice access-node-ip {
        description
          "Indicates the l3-interface for anip.";
        leaf meth {
          type string {
            length "1..32";
            pattern "MEth0";
          }
          description
            "Indicates the anip refers to meth0.";
        }
        leaf loopback {
          type string {
            length "1..32";
            pattern "LoopBack([1-2]{0,1}[0-9]|3[0-1])";
          }
          description
            "Indicates the anip refers to loopback port ranged from 0 to 31.";
        }
        leaf vlanif {
          type string {
            length "1..32";
            pattern "Vlanif(([1-9][0-9]{0,2})|([1-3][0-9]{3})|(40[0-8][0-9])|(409[0-3]))";
          }
          description
            "Indicates the anip refers to vlanif port ranged from 1 to 4093.";
        }
        leaf none {
          type empty;
          description
            "Indicates the anip is not configured.";
        }
      }
      leaf dhcpv6-option37-enterprise-number {
        type uint32 {
          range "0..4294967295";
        }
        default "2011";
        description
          "Indicates the dhcpv6 option37 enterprise number.";
      }
      container dhcp-option82 {
        description
          "Dhcp-option82 raio configuration.";
        leaf mode {
          type raio-mode-options;
          default "common";
          description
            "Dhcp-option82 raio mode.";
        }
        leaf sub-options {
          type sub-option-switch;
          description
            "Dhcp-option82 sub-option status.";
        }
        container format-string {
          description
            "Applied only for user-defined mode.";
          uses raio-format-string;
        }
      }
      container dhcpv6-option {
        description
          "Dhcpv6-option raio configuration.";
        leaf mode {
          type raio-mode-options;
          default "common";
          description
            "Dhcpv6-option raio mode.";
        }
        leaf sub-options {
          type sub-option-switch;
          description
            "Dhcpv6-option sub-option status.";
        }
        container format-string {
          description
            "Applied only for user-defined mode.";
          uses raio-format-string;
        }
      }
      container pitp-pmode {
        description
          "pitp-pmode raio configuration.";
        leaf mode {
          type raio-mode-options;
          default "common";
          description
            "pitp-pmode raio mode.";
        }
        leaf sub-options {
          type sub-option-switch;
          description
            "pitp-pmode sub-option status.";
        }
        container format-string {
          description
            "Applied only for user-defined mode.";
          uses raio-format-string;
        }
      }
      container pitp-vmode {
        description
          "pitp-vmode raio configuration.";
        leaf mode {
          type raio-mode-options;
          default "common";
          description
            "pitp-vmode raio mode.";
        }
        container format-string {
          description
            "Applied only for user-defined mode.";
          uses pitp-vmode-format;
        }
      }
    }
  }

  augment "/huawei-vlan:vlans/huawei-vlan:vlan" {
    description
      "raio profile binded to vlan";
    leaf raio-profile {
      type leafref {
        path "/hw-bb-raio-prof:bb-raio-profiles/hw-bb-raio-prof:raio-profile/hw-bb-raio-prof:name";
      }
      description
        "Augment the raio profile to huawei-vlan";
    }
  }
}
