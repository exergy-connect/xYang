  typedef service-type {
    type enumeration {
      enum "cli" {
        value 0;
        description
          "Indicates the service type is cli.";
      }
      enum "netconf" {
        value 1;
        description
          "Indicates the service type is netconf.";
      }
    }
    description
      "This attribute depicts service state.";
  }

  typedef tm-dst-type {
    type enumeration {
      enum "one-year" {
        value 1;
        description
          "Indicate that the DST type is one-year. It specifies the summer time for a certain year.";
      }
      enum "repeat-date" {
        value 2;
        description
          "Indicate that the DST type is repeat-date. It specifies the summer time for several years.";
      }
      enum "repeat-week" {
        value 3;
        description
          "Indicate that the DST type is repeat-week. It specifies the summer time for several years.";
      }
    }
    description
      "The type of Dst.";
  }

  typedef tm-weeknum {
