module huawei-ietf-system-ext {
  yang-version 1.1;
  namespace "urn:huawei:yang:huawei-ietf-system-ext";
  prefix system-ext;

  import ietf-inet-types {
    prefix inet;
  }
  import ietf-system {
    prefix sys;
  }
  import ietf-yang-types {
    prefix yang;
  }
  import huawei-pub-type {
    prefix pub-type;
  }
  import huawei-extension {
    prefix ext;
  }

  organization
    "Huawei Technologies Co., Ltd.";
  contact
    "Huawei Industrial Base
     Bantian, Longgang
     Shenzhen 518129
     People's Republic of China
     Website: http://www.huawei.com
     Email: support@huawei.com
     ";
  description
    "This module contains a collection of YANG definitions for the
     configuration and identification of some common system
     properties within a device containing a NETCONF server.";

  revision 2025-10-17 {
    description
      "Add nodes for self-healing.";
    reference
      "Huawei private.";
  }
  revision 2025-10-14 {
    description
      "Add node for sysman-firewall.
       Add node for firewall-ip-tables.";
    reference
      "Huawei private.";
  }
  revision 2025-10-11 {
    description
      "Delete network node must constraint.";
    reference
      "Huawei private.";
  }
  revision 2025-08-13 {
    description
      "Add leaf node duration-time to system-state clock.
       Add leaf node description for system.";
    reference
      "Huawei private.";
  }
  revision 2025-03-20 {
    description
      "Add leaf node failed-num to configuration-result-info.
       Modify the specification of leaf-list failed-configuration from 50 to 1000.";
    reference
      "Huawei private.";
  }
  revision 2025-02-22 {
    description
      "Modify the description of configuration-result-info.";
    reference
      "Huawei private.";
  }
  revision 2025-01-02 {
    description
      "Add node for network service.";
    reference
      "Huawei private.";
  }
  revision 2024-11-14 {
    description
      "Initial revision.";
    reference
      "A YANG Data Model for managing sysman network.";
  }
  revision 2024-06-21 {
    description
      "Add node for full yang revision.";
    reference
      "Huawei private.";
  }
  revision 2022-10-01 {
    description
      "Add mqtt in network-service-name.";
    reference
      "Huawei private.";
  }
  revision 2022-07-25 {
    description
      "Add capwap in network-service-name.";
    reference
      "Huawei private.";
  }
  revision 2021-07-08 {
    description
      "Add a container named management-modes.
       Add a list named management-mode.
       Add a leaf node named configuration-type.
       Add a leaf node named mode.";
    reference
      "Huawei private.";
  }
  revision 2020-12-26 {
    description
      "Modify the description of ancp-proxy.
       Modify the description of web-proxy.
       Modify the description of source-interface.
       Modify the description of service-type.
       Add a leaf node named authentication-type.
       Add a leaf node named reenter-num.";
    reference
      "Huawei private.";
  }
  revision 2020-03-06 {
    description
      "Modify dst-configuration.";
    reference
      "Modify dst-configuration.";
  }
  revision 2020-01-03 {
    description
      "This module contains a collection of YANG definitions for the configuration and identification
       of some common system properties within a device containing a NETCONF server. This includes
       data node definitions for user management, and system service source management.";
    reference
      "Network server source list is added for implementing the management of the NETCONF users.";
  }
  revision 2019-09-22 {
    description
      "The modifications by adding dst configuration.";
    reference
      "Huawei private.";
  }
  revision 2019-02-20 {
    description
      "Initial revision.";
    reference
      "A YANG Data Model for managing the NETCONF users.";
  }

 

