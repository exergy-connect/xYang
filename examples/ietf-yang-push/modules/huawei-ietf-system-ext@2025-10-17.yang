  typedef auto-save-switch-status {
    type enumeration {
      enum "on" {
        value 1;
        description
          "Indicates the automatic save is enabled.";
      }
      enum "off" {
        value 2;
        description
          "Indicates the automatic save is disable.";
      }
    }
    description
      "This attribute depicts automatic save status.";
  }

  typedef data-state {
    type enumeration {
      enum "synccompleteness" {
        value 1;
        description
          "indicates that synchronization complete.";
      }
      enum "flashsyncincompleteness" {
        value 2;
        description
          "indicates that operation (loading/backuping/ duplicating/saving/...) is being performed.";
      }
      enum "configbasicdatasyncincompleteness" {
        value 3;
        description
          "indicates that configuration data or basic operation data synchronized incompletely.";
      }
      enum "syncswitchoff" {
        value 4;
        description
          "indicates that the synchronization switch off.";
      }
      enum "peerboardfailure" {
        value 5;
        description
          "indicates that the standby board fail.";
      }
      enum "dynamicdatasyncincompleteness" {
        value 6;
        description
          "indicates that dynamic service data synchronization is incomplete.";
      }
      enum "patchinconsistent" {
        value 7;
        description
          "indicates that patch files of active board and standby board are inconsistent.";
      }
      enum "patchinconsistentdynamicdatasyncincompleteness" {
        value 8;
        description
          "indicates that patch files of active board and standby board are inconsistent and
             dynamic service data synchronization is incomplete.";
      }
      enum "peerboardoffline" {
        value 9;
        description
          "indicates that the standby board doesn't exist.";
      }
    }
    description
      "The data synchronization between the active and standby boards status";
  }

  typedef switch-status {
    type enumeration {
      enum "on" {
        value 1;
        description
          "indicates that the active/standby switchover is enabled.";
      }
      enum "off" {
        value 2;
        description
          "indicates that the active/standby switchover is disabled.";
      }
    }
    description
      "The switch of the active/standby switchover.";
  }

  typedef switch-period {
    type enumeration {
      enum "day" {
        value 1;
        description
          "indicates that the switchover is performed once a day.";
      }
      enum "week" {
        value 2;
        description
          "indicates that the switchover is performed once a week.";
      }
      enum "month" {
        value 3;
        description
          "indicates that the switchover is performed once a month.";
      }
    }
    description
      "The period of the active/standby switchover.";
  }

  typedef auto-status {
    type enumeration {
      enum "on" {
        value 1;
        description
          "indicates that the automatic switchover is enabled.";
      }
      enum "off" {
        value 2;
        description
          "indicates that the automatic switchover is disabled.";
      }
    }
    description
      "Status of auto switchover function.";
  }

