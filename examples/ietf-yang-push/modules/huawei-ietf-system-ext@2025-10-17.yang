      enum "YYYY.MM.DD" {
        value 4;
        description
          "Identifies the date format, for example, 1990.12.31.";
      }
      enum "DD.MM.YYYY" {
        value 5;
        description
          "Identifies the date format, for example, 31.12.1990.";
