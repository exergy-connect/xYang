      enum "DD-MM-YYYY" {
        value 2;
        description
          "Identifies the date format, for example, 31-12-1990.";
      }
      enum "MM-DD-YYYY" {
        value 3;
        description
          "Identifies the date format, for example, 12-31-1990.";
