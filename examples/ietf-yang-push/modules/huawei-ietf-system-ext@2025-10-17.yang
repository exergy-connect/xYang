  typedef mode {
    type enumeration {
      enum "default" {
        value 0;
        description
          "Indicates that the system service-provisioning config-mode is default.";
      }
      enum "netconf" {
        value 1;
        description
          "Indicates that the system service-provisioning config-mode is netconf.";
      }
