  grouping network-server-source-interface-list {
    description
      "A collection of YANG definitions for setting the source interface bound to the system services.";
    list network-server-source-interface {
      key "protocol-type source-interface";
      description
        "Configure the server protocol type and source-interface related to sockets.";
      leaf protocol-type {
        type network-service-name;
        description
          "Network protocol name.";
      }
      leaf source-interface {
        type string {
          length "1..63";
        }
        description
          "Specify the ifName which is bound to the service, 'any-interface' means bound to all interface.";
      }
    }
  }

  grouping network-server-source-ip-list {
    description
      "A collection of YANG definitions for setting the source ip-address bound to the system services.";
    list network-server-source-ip {
      key "protocol-type source-ip";
      description
        "Configure the server protocol type and source ip-address related to sockets.";
      leaf protocol-type {
        type network-service-name;
        description
          "Network protocol name.";
      }
      leaf source-ip {
        type inet:ip-address;
        description
          "Specific ip address.";
      }
      leaf vrf-name {
        type string {
          length "1..31";
        }
        description
          "VRF name on a server. When the ip-address is all zeros, the vrf-name cannot be configured.";
      }
    }
  }

  grouping network-source-interface-list {
    description
      "A collection of YANG definitions for setting the source interface bound to the system services.";
    list network-source-interface {
      key "source-protocol-type";
      description
        "Configure the server protocol type and source-interface related to sockets.";
      leaf source-protocol-type {
        type identityref {
          base sys-service-type;
        }
        description
          "Source protocol name.";
      }
      leaf source-interface {
        type string {
          length "1..63";
        }
        mandatory true;
        description
          "Specify the ifName which is bound to the service, support 'meth' 'loopback' 'vlanif'";
      }
      leaf source-interface-index {
        type uint32;
        mandatory true;
        description
          "Specify the ifName which is bound to the service, support 'meth 0' 'loopback 1-31' 'vlanif 1-4093'";
      }
    }
  }

  grouping network-source-ip-list {
    description
      "A collection of YANG definitions for setting the source ip-address bound to the system services.";
    list network-source-ip {
      key "source-protocol-type";
      description
        "Configure the server protocol type and source ip-address related to sockets.";
      leaf source-protocol-type {
        type identityref {
          base sys-service-type;
        }
        description
          "Source protocol name.";
      }
      leaf source-ipv6 {
        type inet:ipv6-address;
        mandatory true;
        description
          "Specific ipv6 address.";
      }
    }
  }

  grouping network-service-interface-list {
    description
      "A collection of YANG definitions for setting the source interface bound to the system services.";
    list network-service-interface {
      key "service-protocol-type";
      description
        "Configure the service protocol type";
      leaf service-protocol-type {
        type identityref {
          base sys-service-type;
        }
        description
          "Service support dhcp-relay,dhcpv6-relay,ipdr,ntp,ntp6,portal,radius,snmp,snmpv6,ssh,sshv6,telnet,telnetv6,trace,twamp,netconf,mqtt,web-proxy.";
      }
      leaf service-state {
        type com-status-type;
        mandatory true;
        description
          "Service status";
      }
    }
  }

  grouping network-service-port-interface-list {
    description
      "A collection of YANG definitions for setting the source interface bound to the system services.";
    list network-service-port-interface {
      key "service-port-protocol-type";
      description
        "Configure the service protocol type";
      leaf service-port-protocol-type {
        type identityref {
          base sys-service-type;
        }
        description
          "Service support set telnet,telnetv6,netconf,ssh,sshv6, query all.";
      }
      leaf service-port {
        type uint32;
        mandatory true;
        description
          "Service port value";
      }
    }
  }

  grouping network-service-port-client-list {
    description
      "A collection of YANG definitions for querry the system services ftp and sftp.";
    list network-service-port-client {
      key "client-type";
      config false;
      description
        "Configure the service client type";
      leaf client-type {
        type identityref {
          base sys-service-type;
        }
        must "((.='system-ext:ftp-client') or (.='system-ext:sftp-client') or (.='system-ext:radius'))";
        description
          "Service ftp/sftp client.";
      }
      leaf-list port-value {
        type uint32;
        description
          "Service port value";
      }
    }
  }

  augment "/sys:system/sys:authentication/sys:user" {
    description
      "For the user's attribute operation, indicates the service type, authentication type, repeated logins of a user.";
    leaf service-type {
      type service-type;
      default "netconf";
      description
        "The service type for this entry.";
    }
    leaf authentication-type {
      type authentication-type;
      default "password";
      description
        "The authentication type for this entry.";
    }
    leaf reenter-num {
      type uint32 {
        range "0..20";
      }
      default "1";
      description
        "The number of repeated logins allowed.";
    }
    leaf level {
      type user-level;
      default "common";
      description
        "The levels of CLI users.
         The higher the user level is, the more rights the user has.
         The user level must be bound to the user when the user is added.
         The super administrator cannot be added.";
    }
    leaf description {
      type string {
        length "1..100";
      }
      default "-----";
      description
        "Description of CLI user.
         You can add the basic information about the user,
         such as the email box, telephone number, or other contact information.";
    }
    leaf profile {
      type string {
        length "1..15";
      }
      default "root";
      description
        "The name of user profile that CLI user belongs to.";
    }
    leaf name-validity-period {
      type int32;
      units "d";
      config false;
      description
        "Remaining validity days of user name.
         The value of -1 indicates the username expired.";
    }
    leaf password-validity-period {
      type int32;
      units "d";
      config false;
      description
        "Remaining validity days of user password.
         The value of -1 indicates the user password expired.";
    }
    leaf is-emergency-account {
      type boolean;
      must "../is-emergency-account='false' or (../is-emergency-account='true' and ../service-type='cli')" {
        error-message
          "Netconf users cannot be configured as emergency accounts.";
      }
      default "false";
      description
        "Enable/disable [This object indicates the type of the terminal user is a general user or an emergency user].";
    }
  }
  augment "/sys:system/sys:authentication" {
    description
      "Augment is sys:authentication.";
    container user-clients {
      description
        "List of the user-clients.";
      list user-client {
        key "id";
        description
          "Configure the cli online user information table, which can be used to force an online user to go offline.";
        leaf id {
          type int32 {
            range "1..255";
          }
          description
            "This ID is allocated by device.
             Value 255 indicates that the device does not allocate client IDs.";
        }
        leaf username {
          type string {
            length "1..34";
          }
          config false;
          description
            "User name of client.";
        }
        leaf type {
          type client-type;
          config false;
          description
            "Type of client.";
        }
        leaf login-datetime {
          type yang:date-and-time;
          config false;
          description
            "The login time of client.";
        }
        leaf ip-type {
          type inet:ip-version;
          config false;
          description
            "The type of client address.";
        }
        leaf client-ip {
          type inet:ip-address;
          config false;
          description
            "The object specifies the IP address of client.";
        }
        action disconnect {
          description
            "Force a online user to go offline.";

          output {
            leaf result {
              type string {
                length "1..2048";
              }
              description
                "The result of forcing a user to disconnect.";
            }
          }
        }
      }
    }
  }
  augment "/sys:system/sys:clock/sys:timezone/sys:timezone-utc-offset" {
    description
      "For the user-define time zone name.";
    leaf timezone-name {
      type string {
        length "1..32";
      }
      default "DefaultZoneName";
      description
        "Specify the name of a time zone. The length of string is from 1 to 32 characters.";
    }
  }
  augment "/sys:system/sys:clock" {
    description
      "For the user-define dst.";
    container dst-configuration {
      must
        "((type='one-year' and start-year and start-month and start-day and start-time and end-year and end-month and end-day and end-time and dst-offset)
         or(type='repeat-date' and start-month and start-day and start-time and end-month and end-day and end-time and dst-offset)
         or(type='repeat-week' and start-month and start-weeknum and start-weekday and start-time and end-month and end-weeknum and end-weekday and end-time and dst-offset))";
      presence "Enable dst";
      description
        "Enable/disable daylight saving time (DST).
         The start date and start week cannot be configurated at the save time.
         The end date and end week can not be configurated at the save time either.
         The dst-offset must be less than the time difference between the end time and the start time.";
      leaf dst-name {
        type string {
          length "1..32";
        }
        description
          "Specify a DST name. The length of string is from 1 to 32 characters.";
      }
      leaf type {
        type tm-dst-type;
        description
          "Specify whether this setting is for one year or repeating.";
      }
      leaf start-year {
        type uint16 {
          range "2000..2037";
        }
        description
          "Specify the daylight saving start year. It is in the format of YYYY. The value of YYYY ranges from 2000 to 2037.";
      }
      leaf start-month {
        type tm-month;
        description
          "Specify the daylight saving start month. The value can be January, February, March, April, May, June, July, August, September, October, November, or December.";
      }
      leaf start-day {
        type tm-date;
        description
          "Specify the daylight saving start date. It is in the format of DD. The value of DD ranges from 1 to 31.";
      }
      leaf start-weeknum {
        type tm-weeknum;
        description
          "Specify the start week number in the specified month. The value can be first, second, third, fourth, or last.";
      }
      leaf start-weekday {
        type tm-weekday;
        description
          "Specify the start weekday. The value can be Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, or Sunday.";
      }
      leaf start-time {
        type pub-type:time;
        description
          "Specify the daylight saving start time. The value of HH ranges from 0 to 23, and the values of MM and SS range from 0 to 59.";
      }
      leaf end-year {
        type uint16 {
          range "2000..2037";
        }
        description
          "Specify the daylight saving end year. It is in the format of YYYY. The value of YYYY ranges from 2000 to 2037.";
      }
      leaf end-month {
        type tm-month;
        description
          "Specify the daylight saving end month. The value can be January, February, March, April, May, June, July, August, September, October, November, or December.";
      }
      leaf end-day {
        type tm-date;
        description
          "Specify the daylight saving end date. It is in the format of DD. The value of DD ranges from 1 to 31.";
      }
      leaf end-weeknum {
        type tm-weeknum;
        description
          "Specify the end week number in the specified month. The value can be first, second, third, fourth, or last.";
      }
      leaf end-weekday {
        type tm-weekday;
        description
          "Specify the end weekday. The value can be Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, or Sunday.";
      }
      leaf end-time {
        type pub-type:time;
        description
          "Specify the daylight saving end time. The value of HH ranges from 0 to 23, and the values of MM and SS range from 0 to 59.";
      }
      leaf dst-offset {
        type pub-type:time-hhmm;
        description
          "Specify the time added to the summer time. It is in the format of HH:MM.";
      }
    }
    leaf time-stamp {
      type enumeration {
        enum "local" {
          value 1;
          description
            "Indicates that the time stamp uses the local time of the node.";
        }
        enum "utc" {
          value 2;
          description
            "Indicates that the time stamp uses the UTC(Universal Time Coordinated) time.";
        }
      }
      default "utc";
      description
        "The time information in the trap and syslog uses the formats of the time stamp.";
    }
    leaf date-format {
      type date-format-type;
      default "YYYY-MM-DD";
      description
        "Configuring the system date format. After the configuration takes effect,
         all contents related to date display in the system are displayed in the specified format.";
    }
  }
  augment "/sys:system" {
    description
      "Network server.";
    container network-server {
      description
        "Configure the source interface or source ip-address bound to the system services.";
      container network-server-source-interfaces {
        description
          "Configure the source interface bound to the system services.";
        uses network-server-source-interface-list;
      }
      container network-server-source-ips {
        description
          "Configure the source ip-address bound to the system services.";
        uses network-server-source-ip-list;
      }
    }
  }
  augment "/sys:system" {
    description
      "Config network source.";
    container network-source {
      description
        "Contain network source.";
      container network-source-interfaces {
        description
          "Configure the source interface bound to the system services.";
        uses network-source-interface-list;
      }
      container network-source-ips {
        description
          "Configure the ipv6 address bound to the system services.";
        uses network-source-ip-list;
      }
    }
  }
  augment "/sys:system" {
    description
      "Configure network service.";
    container network-service {
      description
        "Contain network service.";
      container network-service-interfaces {
        description
          "Configure the source interface bound to the system services.";
        uses network-service-interface-list;
      }
    }
  }
  augment "/sys:system" {
    description
      "Config network service port.";
    container network-service-port {
      description
        "Contain network service port.";
      container network-service-port-interfaces {
        description
          "Configure the source interface port bound to the system services.";
        uses network-service-port-interface-list;
      }
      container network-service-port-clients {
        description
          "source interface ftp and sftp config.";
        uses network-service-port-client-list;
      }
    }
  }
  augment "/sys:system" {
    description
      "Configure network console.";
    container network-console {
      description
        "Contain network console.";
      leaf console-state {
        type com-status-type;
        description
          "Configure the sysman console.";
      }
    }
  }
  augment "/sys:system" {
    description
      "Configure network vpn-instance.";
    container network-vpn-instance {
      description
        "Contain network vpn-instance.";
      leaf ipv6-vpn-instance-name {
        type string {
          length "1..31";
        }
        description
          "Configure the vpn instance name.";
      }
      leaf vpn-instance-name {
        type string {
          length "1..31";
        }
        description
          "Configure the vpn instance name.";
      }
    }
  }
  augment "/sys:system" {
    description
      "For the system config.";
    container management-modes {
      description
        "List of system management-modes.";
      list management-mode {
        key "configuration-type";
        description
          "Configure the management-modes to the system services.";
        leaf configuration-type {
          type identityref {
            base configuration-type;
          }
          description
            "The system configuration-type.";
        }
        leaf mode {
          type mode;
          mandatory true;
          description
            "The system service-provisioning config-mode.";
        }
      }
    }
  }
  augment "/sys:system" {
    description
      "For the system config.";
    container auto-save-policys {
      description
        "List of configure automatic save policy.";
      list auto-save-policy {
        key "auto-save-type";
        description
          "Configure automatic save configuration for type.";
        leaf auto-save-type {
          type save-type;
          description
            "The type of automatic saving.";
        }
        leaf auto-save-interval-switch {
          type auto-save-switch-status;
          default "off";
          description
            "Automatic save switch.";
        }
        leaf auto-save-interval {
          type uint32 {
            range "60000..60480000";
          }
          description
            "The period of automatic data saving. The period is in the unit of 10 ms,
              with a value range of 60000-60480000 (10 minutes to one week).
              If the data saving is enabled, the data default value of this object is 8640000 (one day),
              which indicates that the data saving is performed automatically once a day, the Configuration files
              default value of this object is 8460000.";
        }
        leaf auto-save-time-switch {
          type auto-save-switch-status;
          default "on";
          description
            "Automatic save absolute switch.";
        }
        leaf auto-save-time {
          type uint32;
          description
            "The time of automatic data saving. This value can be converted into the hexadecimal
              number 0x00hhmmss (hh representing hour, mm representing minute,
              and ss representing second), and then can be converted into the value of
              the object through a decimal conversion. If the time of automatic data saving
              needs to be set to 22:30:00 the corresponding value is 0x00161E00=1449472,
              with 1449472 being the set value.";
        }
        leaf auto-save-change-interval {
          type uint32 {
            range "12000..8640000";
          }
          default "180000";
          description
            "Automatic saving of configuration changed. The time is in the unit of 10 ms,with
             a value range of 12000-8640000 (two minutes to one day). If the value of the object
             hwAutoSaveType is configuration(2), it is 180000 (30 minutes) by default, which indicates that the
             configuration files or database are saved automatically each 30 minutes.";
        }
      }
    }
  }
  augment "/sys:system" {
    description
      "For the system config.";
    container system-switchover {
      description
        "Configure the operation of system switch-over.";
      leaf system-switch-status {
        type switch-status;
        default "on";
        description
          "The switch of the active/standby switchover.
           Options:
           1. on(1) -shows that the active/standby switchover is enabled.
           2. off(2) -shows that the active/standby switchover is disabled.
           If the active/standby switchover is disabled, the system cannot
           perform data synchronization between the active and standby control
           boards, manual active/standby switchover,
           and automatic active/standby switchover.
           Default:on(1).";
      }
      action switchover {
        description
          "Manual active/standby switchover.";

        input {
          leaf retry-time {
            type uint32 {
              range "0..180";
            }
            units "seconds";
            default "0";
            description
              "Timeout for retry after switchover failure, default is 0.";
          }
        }
      }
    }
    container auto-switchover-control {
      description
        "Configure control the active/standby auto switchover.";
      leaf period {
        type switch-period;
        description
          "The period of the active/standby switchover.
           Options:
           1. day(1) -indicates that the switchover is performed once a day.
           2. week(2) -indicates that the switchover is performed once a week.
           3. month(3) -indicates that the switchover is performed once a month.
           Default { day }";
      }
      leaf day-of-period {
        type uint32;
        description
          "Days since the periodic switchover has been started. Its value
           range depends on the value of object period.
           When period is set to day(1), the default value of this object is 1;
           When period is set to week(2), the value range of this object is 1-7
           When period is set to month(3), the value range of this object is 1-31.
           Default:1.";
      }
      leaf time {
        type string {
          length "8";
        }
        description
          "Time when switchover will happen. Time is set by a string in the format of hh:mm:ss.
           The value range of hh is from 00 to 23. The value range of mm is from 00 to 59.
           The value range of ss is from 00 to 59.
           Default:03:00:00.";
      }
      leaf auto-switch-status {
        type auto-status;
        description
          "Status of auto switchover function. If the value of system-switch-status
           is off(2), the system cannot perform the active/standby switchover.
           Options:
           1.on(1) -shows that the auto switchover is enabled. In this case,
                  if the values of the period, day-of-period,
                  and time are set, the system performs the auto switchover periodically;
                  if the values of the period, day-of-period, and time
                  are not set or only partially set, the objects that are not set with values use the default
                  value, and the system also performs the auto switchover periodically.
           2.off(2) -shows that the auto switchover is disabled. If this object is not set with a value,
                  the system does not perform the auto switchover.
           Default { off }.";
      }
    }
  }
  augment "/sys:system" {
    description
      "For the system config.";
    container alarm-thresholds {
      description
        "List of overload resource threshold. When the resource usage exceeds this value, an alarm is reported.";
      list alarm-threshold {
        key "type one-level";
        description
          "Configure an overload threshold for a specific resource. When the resource usage exceeds this value, an alarm is reported.";
        leaf type {
          type identityref {
            base threshold-type;
          }
          description
            "The type of the specific threshold.";
        }
        leaf one-level {
          type union {
            type uint32;
            type enumeration {
              enum "alarm" {
                value 1;
                description
                  "Respond by alarm that the system resource uses when it exceeds the threshold.";
              }
            }
          }
          description
            "The response that the system resource uses when it exceeds the threshold. The actions that can be taken in the future include: alarm, reboot, switch-over.";
        }
        leaf threshold {
          type union {
            type uint32;
          }
          description
            "The value of the specific for severity level alarm.";
        }
      }
    }
  }
  augment "/sys:system" {
    description
      "Augment the description information for system.";
    leaf description {
      type string {
        length "1..200";
      }
      description
        "The description of the device.";
    }
  }
  augment "/sys:system" {
    description
      "For the system config.";
    container self-healing {
      description
        "Configure for system self-healing features including reboot, switch-over, and application restart.";
      container reboot {
        description
          "Configure for system reboot self-healing strategy.";
        container type {
          description
            "Configure for type of reboot strategy: scheduled, memory-based, or forward-path.";
          leaf enabled {
            type boolean;
            description
              "Enable/disable reboot strategy.";
          }
          container scheduled {
            description
              "Configure for scheduled reboot strategy.";
            leaf start-time {
              type pub-type:time;
              description
                "Start time for the scheduled reboot.";
            }
            leaf end-time {
              type pub-type:time;
              description
                "End time for the scheduled reboot.";
            }
          }
          container memory {
            description
              "Configure for memory-based reboot strategy.";
            leaf graceful {
              type boolean;
              description
                "Enable/disable graceful reboot based on memory usage.";
            }
            leaf enabled {
              type boolean;
              description
                "Enable/disable memory-based reboot strategy.";
            }
          }
          container forward-path {
            description
              "Configure for forward-path reboot strategy.";
            leaf enabled {
              type boolean;
              description
                "Enable/disable forward-path reboot strategy.";
            }
          }
        }
      }
      container switch-over {
        description
          "Configure for system switch-over self-healing strategy.";
        leaf enabled {
          type boolean;
          description
            "Enable/disable switch-over strategy.";
        }
        leaf forward-path {
          type boolean;
          description
            "Enable/disable forward-path for switch-over strategy.";
        }
      }
      container app-restart {
        description
          "Configure for application restart self-healing strategy.";
        leaf enabled {
          type boolean;
          description
            "Enable/disable application restart strategy.";
        }
      }
    }
  }
  augment "/sys:system-state" {
    description
      "System status information.";
    container configuration-result-info {
      config false;
      description
        "Statistics of configuration restoration result.";
      leaf configuration-result {
        type enumeration {
          enum "success" {
            value 0;
            description
              "Indicates all configurations are successfully restored.";
          }
          enum "failure" {
            value 1;
            description
              "Indicates that some configurations fail to be restored.";
          }
        }
        description
          "Indicates the result of configuration restoration.";
      }
      leaf failed-num {
        type uint32;
        description
          "Indicates the number of configurations that fail to be restored.";
      }
      leaf-list failed-configuration {
        type string {
          length "1..1024";
        }
        max-elements 1000;
        description
          "Operational data of fails to be restored.
           When the configuration result is success, the information is NULL.
           If there are too many configuration failures, only the first 1000 records are displayed.";
      }
    }
    container system-data-state {
      config false;
      description
        "Operational state of the info about system switchover or the status of data synchronization.";
      leaf data-sync-state {
        type data-state;
        config false;
        description
          "Operational state of the query of the status of data synchronization between
           the active and standby control boards.
           Options:
           1. synccompleteness(1)
             -shows that synchronization complete.
           2. flashsyncincompleteness(2)
             -shows that operation (loading/backuping/duplicating/saving/...) is being performed.
           3. configbasicdatasyncincompleteness(3)
             -shows that configuration data or basic operation data synchronized incompletely.
           4. syncswitchoff(4)
             -shows that the synchronization switch off.
           5. peerboardfailure(5)
             -shows that the standby board fail.
           6. dynamicdatasyncincompleteness(6)
             -shows that dynamic service data synchronization is incomplete.
           7. patchinconsistent(7)
             -shows that patch files of active board and standby board are inconsistent.
           8. patchinconsistentdynamicdatasyncincompleteness(8)
             -shows that patch files of active board and standby board are inconsistent and
             dynamic service data synchronization is incomplete.
           9. peerboardoffline(9)
             -shows that the standby board doesn't exist.";
      }
    }
    container system-data-info {
      config false;
      description
        "System data information statistics.";
      leaf data-init-state {
        type data-status;
        description
          "Querying database state when system init.";
      }
      leaf data-persistence-id {
        type uint32;
        description
          "Save the database and generate an ID information to verify the data consistency of the controller and device.";
      }
      leaf data-changes {
        type uint32;
        description
          "Querying whether the system configuration (database and configuration files) changes.";
      }
      leaf data-state {
        type data-status;
        description
          "Querying whether the current database is null. A null database refers to the database
           with no configuration data.";
      }
    }
  }
  augment "/sys:system-state/sys:clock" {
    description
      "Augment the clock of system state to provide additional.";
    leaf duration-time {
      type string;
      config false;
      description
        "The total time the system has been running since startup.";
    }
  }
  augment "/sys:system" {
    description
      "Information of sysman-firewall and firewall-ip-tables data.";
    container sysman-firewall {
      description
        "Configure sysman firewall switch and ip rule.";
      container firewall-switch-tables {
        description
          "List of sysman firewall configure.";
        list firewall-switch-table {
          key "ip-version protocol-type";
          description
            "Configure firewall protocol switch.";
          leaf ip-version {
            type inet:ip-version;
            description
              "Configure the ip version IPv4/IPv6.";
          }
          leaf protocol-type {
            type firewall-protocol-type;
            description
              "Configure protocol type.";
          }
          leaf firewall-switch {
            type com-status-type;
            mandatory true;
            description
              "Configure firewall switch.";
          }
        }
      }
      container firewall-ip-tables {
        description
          "List of contain firewall ip rules.";
        list firewall-ip-table {
          key "ip-rule protocol-type ip-start";
          description
            "Configure ip rules.";
          leaf ip-rule {
            type enumeration {
              enum "refuse" {
                value 0;
                description
                  "Indicates firewall ip blacklist.";
              }
              enum "access" {
                value 1;
                description
                  "Indicates firewall ip whitelist.";
              }
            }
            description
              "Configure the ip rules access or refuse.";
          }
          leaf protocol-type {
            type firewall-protocol-type;
            description
              "Configure protocol type.";
          }
          leaf ip-start {
            type inet:ip-address;
            description
              "Configure ip range start.";
          }
          leaf ip-end {
            type inet:ip-address;
            mandatory true;
            description
              "Configure ip range end.";
          }
          leaf ip-version {
            type inet:ip-version;
            mandatory true;
            description
              "Configure the ip version IPv4/IPv6.";
          }
        }
      }
    }
  }
}
