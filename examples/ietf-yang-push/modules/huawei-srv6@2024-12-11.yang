                }
              }
            }
            container end-ms {
              description
                "List of End.M type opcode configuration.";
              list end-m {
                must "../../../static-length>0 and ../../../flex-algo=0";
                key "value mirror-prefix mirror-mask";
                description
                  "Configure End.M type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
                leaf mirror-prefix {
                  type inet:ipv6-address-no-zone;
                  description
