                must "not(count(../end-dt4[protocol='evpn-l3vpn'][vpn-name=current()/vpn-name]) != 0 and count(../end-dt4[protocol!='evpn-l3vpn'][vpn-name=current()/vpn-name]) != 0)";
                key "value";
                unique "vpn-name protocol";
