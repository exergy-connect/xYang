  augment "/ni:network-instance/ni:instances/ni:instance" {
    description
      "Segment routing IPv6 augment to L3VPN.";
    container srv6 {
      when "../ni:name='_public_'";
      description
        "Configure segment routing IPv6.";
      leaf enable {
        type boolean;
        default "false";
        description
          "Enable/disable segment routing IPv6.";
      }
      leaf te-frr-enable {
        type boolean;
        must "../te-frr-enable='false' or ../enable='true'";
        default "false";
        description
          "Enable/disable SR TE FRR.";
      }
      leaf te-frr-enable-downgrade {
        when "../te-frr-enable='true'";
        type boolean;
        default "false";
        description
          "Enable/disable fast re-route mode.";
      }
      leaf te-frr-verify-trusted-domain {
        type boolean;
        must "../te-frr-verify-trusted-domain='false' or ((../enable='true') and count(../trusted-domains/trusted-domain-destinations/trusted-domain-destination)>0)";
        default "false";
        description
          "Enable/disable SRv6 TE FRR with trusted domain verification.";
      }
      leaf end-x-delay-time {
        when "../enable='true'";
        type uint32 {
          range "0..600000";
        }
        units "ms";
        default "0";
        description
          "End.X delay time.";
      }
      leaf te-frr-delay-time {
        when "../enable='true'";
        type uint32 {
          range "1..600000";
        }
        units "ms";
        description
          "TE FRR delay time.";
      }
      leaf path-mtu {
        when "../enable='true'";
        type uint32 {
          range "1280..9600";
        }
        must "(../path-mtu-reserved and (../path-mtu)-(../path-mtu-reserved)>=1280) or not(../path-mtu-reserved)";
        default "9600";
        description
          "Path MTU value.";
      }
      leaf path-mtu-reserved {
        when "../enable='true'";
        type uint32 {
          range "1..9600";
        }
        must "(../path-mtu)-(../path-mtu-reserved)>=1280";
        description
          "Path MTU reserved value.";
      }
      leaf proxy-peer-sid {
        when "../enable='true'";
        type inet:ipv6-address-no-zone;
        description
          "Peer SID of SFC for anycast.";
      }
      leaf reduce-srh-enable {
        when "../enable='true'";
        type boolean;
        default "false";
        description
          "Enable/disable reduce SRH.";
      }
      leaf local-end-x-encapsulation {
        when "../enable='true'";
        type boolean;
        default "false";
        description
          "Enable/disable local End.X SID encapsulation.";
      }
      leaf compress-16-mode {
        when "../enable='true'";
        type compress-16-mode-type;
        description
          "Configure the SRv6 compress-16 mode.";
      }
      leaf protected-end-x-delete-delay {
        when "../enable='true'";
        type uint32 {
          range "30..1800";
        }
        units "s";
        default "900";
        description
          "Protected End.X delete delay time.";
      }
      container csid-proportion {
        when "../enable='true'";
        description
          "Configure the proportion of compressed SIDs.";
        leaf global-id-block {
          type uint8 {
            range "1..255";
          }
          must "(../space=4 and ../global-id-block<16) or (../space=5 and ../global-id-block<32) or (../space=6 and ../global-id-block<64) or (../space=7 and ../global-id-block<128) or (../space=8)";
          default "14";
          description
            "Ratio of GIBs in compressed SIDs.";
        }
        leaf space {
          type uint8 {
            range "4..8";
          }
          default "4";
          description
            "Configure the proportion space of compressed SIDs.";
        }
      }
      container bfd {
        when "../enable='true'";
        description
          "Configure SRv6 locator BFD parameters.";
        leaf sbfd-enable {
          type boolean;
          default "false";
          description
            "Enable/disable seamless BFD on all locators.";
        }
        leaf min-tx {
         
          type uint32 {
            range "3..20000";
          }
          units "ms";
          description
            "Set the minimum interval at which BFD packets are sent.";
        }
        leaf min-rx {
         
          type uint32 {
            range "3..20000";
          }
          units "ms";
          description
            "Set the minimum interval at which BFD packets are received.";
        }
        leaf detect-multiplier {
          type uint32 {
            range "3..50";
          }
          default "3";
          description
            "Set the detection multiplier of a BFD session.";
        }
        leaf ipv6-prefix {
          when "../sbfd-enable='true'";
          type leafref {
            path "/rtp:routing-policy/rtp:ipv6-prefix-filters/rtp:ipv6-prefix-filter/rtp:name";
          }
          description
            "Set the name of an IPv6 prefix list.";
        }
      }
      container encapsulation {
        when "../enable='true'";
        description
          "Configure IPv6 encapsulation configuration.";
        choice mode {
          description
            "Configure the SRv6 encapsulation model.";
          case address {
            description
              "Source address mode.";
            leaf source-address {
              type inet:ipv6-address-no-zone;
              description
                "SRv6 VPN encapsulation source address.";
            }
          }
          case interface {
            description
              "Source interface mode.";
            leaf source-interface {
              type leafref {
                path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
              }
              must "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name=current()]/ifm:type='LoopBack'";
              description
                "This interface is specified as the interface for SRv6 source address encapsulation.";
            }
          }
        }
        leaf hop-limit {
          when "../source-address or ../source-interface";
          type uint8 {
            range "1..255";
          }
          default "255";
          description
            "Encapsulation IPv6 header TTL value.";
        }
      }
      container trusted-domains {
        when "../enable='true'";
        presence "TE FRR trusted domain view.";
        description
          "Configure SRv6 TE FRR trusted domains.";
        container trusted-domain-destinations {
          description
            "List of SRv6 TE FRR trusted domain destinations.";
          list trusted-domain-destination {
            key "destination mask-length";
            max-elements 1024;
            description
              "Configure SRv6 TE FRR trusted domain.";
            leaf destination {
              type inet:ipv6-address-no-zone;
              description
                "Destination IPv6 prefix.";
            }
            leaf mask-length {
              type uint8 {
                range "1..128";
              }
              description
                "Destination mask length.";
            }
          }
        }
      }
      container locators {
        when "../enable='true'";
        description
          "List of SRv6 locator configuration.";
        list locator {
          key "name";
          unique "prefix";
          description
            "Configure SRv6 locator configuration.";
          leaf name {
            type string {
              length "1..31";
            }
            description
              "Locator name.";
          }
          leaf prefix {
           
            type inet:ipv6-address-no-zone;
            mandatory true;
            description
              "IPv6 prefix.";
          }
          leaf prefix-length {
           
            type uint8 {
              range "32..120";
            }
            must "../prefix-length+../static-length+../args-length<=128";
            mandatory true;
            description
              "Mask length. The maximum sum value of the mask length, static segment length, and argument segment length is 128.";
          }
          leaf static-length {
           
            type uint8 {
              range "0..96";
            }
            must "../prefix-length+../static-length+../args-length<=128";
            default "0";
            description
              "The static segment length determines the range of opcode. The maximum sum value of the mask length, static segment length, and argument segment length is 128.";
          }
          leaf args-length {
           
            type uint8 {
              range "0..64";
            }
            must "../prefix-length+../static-length+../args-length<=128";
            default "0";
            description
              "Argument segment length. The maximum sum value of the mask length, static segment length, and argument segment length is 128.";
          }
          choice compress-mode {
            description
              "Configure compress mode.";
            case compress-block-length {
              description
                "The compression type is 32-bit compression.";
              leaf compress-block-length {
               
                type uint8 {
                  range "1..88";
                }
                must "((../compress-block-length mod 4)=0) and (../compress-block-length>=4) and (../compress-block-length<=128) and (../prefix-length - ../compress-block-length>=1) and (../prefix-length - ../compress-block-length<=31)";
                description
                  "Block segment length. The block segment length is within the range of prefix length.";
              }
            }
            case compress-16 {
              description
                "The compression type is 16-bit compression.";
              leaf compress-16 {
               
                type empty;
                must "((../prefix-length mod 4)=0) and (../prefix-length<=92) and ../../../compress-16-mode";
                description
                  "The compression type is 16-bit compression, the node segment length is 16.";
              }
            }
          }
          leaf compress-static-length {
            when "../compress-block-length or ../compress-16";
            type uint8 {
              range "1..32";
            }
            must "../compress-block-length and (../compress-static-length<=32 - (../prefix-length - ../compress-block-length)) or ../compress-16 and ../compress-static-length<=16";
            description
              "Compress static segment length. The compress static segment length is within the range of compress length.";
          }
          leaf flex-algo {
           
            type uint8 {
              range "0|128..255";
            }
            default "0";
            description
              "Flexible algorithm.";
          }
          container preference {
            presence "The preference for the locator.";
            description
              "Configure the locator preference.";
            leaf value {
              type uint8 {
                range "1..255";
              }
              mandatory true;
              description
                "The locator preference value.";
            }
          }
          container srv6lbs {
            description
              "List of segment routing IPv6 local blocks reserved for BSIDs.";
            list srv6lb {
              key "index";
              max-elements 1;
              description
                "Configure segment routing IPv6 local block reserved for BSIDs. Currently only one configuration is supported.";
              leaf index {
                type uint32;
                description
                  "The identifier of a segment routing IPv6 local block.";
              }
              leaf begin-value {
                type inet:ipv6-address-no-zone;
                description
                  "Begin value of the local block for SRv6 SIDs.";
              }
              leaf sid-reserve-number {
                type uint32 {
                  range "1..200000";
                }
                mandatory true;
                description
                  "The number of SIDs reserved for BSIDs in local block.";
              }
            }
          }
          container opcodes {
            description
              "Configure SRv6 opcodes configuration.";
            container ends {
              description
                "List of End type opcode configuration.";
              list end {
                must "../../../static-length>0 or ../../../compress-static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
                leaf compress {
                 
                  type boolean;
                  must "(../compress = 'true' and (../../../../compress-block-length>0 or ../../../../compress-16) and (../../../../compress-static-length>0)) or ../compress = 'false'";
                  default "false";
                  description
                    "Enable/disable compress function.";
                }
              }
            }
            container end-psps {
              description
                "List of End psp type opcode configuration.";
              list end-psp {
                must "../../../static-length>0 or ../../../compress-static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End psp type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
                leaf compress {
                 
                  type boolean;
                  must "(../compress = 'true' and (../../../../compress-block-length>0 or ../../../../compress-16) and (../../../../compress-static-length>0)) or ../compress = 'false'";
                  default "false";
                  description
                    "Enable/disable compress function.";
                }
              }
            }
            container end-psp-usp-usds {
              description
                "List of End psp-usp-usd type opcode configuration.";
              list end-psp-usp-usd {
                must "../../../static-length>0 or ../../../compress-static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End psp-usp-usd type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
                leaf compress {
                 
                  type boolean;
                  must "(../compress = 'true' and (../../../../compress-block-length>0 or ../../../../compress-16) and (../../../../compress-static-length>0)) or ../compress = 'false'";
                  default "false";
                  description
                    "Enable/disable compress function.";
                }
              }
            }
            container end-psp-usp-usd-cocs {
              description
                "List of End psp-usp-usd-coc type opcode configuration.";
              list end-psp-usp-usd-coc {
                must "../../../compress-static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End psp-usp-usd-coc type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
              }
            }
            container end-cocs {
              description
                "List of End coc type opcode configuration.";
              list end-coc {
                must "../../../compress-static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End coc type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
              }
            }
            container end-psp-cocs {
              description
                "List of End psp-coc type opcode configuration.";
              list end-psp-coc {
                must "../../../compress-static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End psp-coc type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
              }
            }
            container end-ops {
              description
                "List of End.OP type opcode configuration.";
              list end-op {
                must "../../../static-length>0";
                key "value";
                max-elements 1;
                description
                  "Configure End.OP type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
              }
            }
            container end-xs {
              description
                "List of End.X type opcode configuration.";
              list end-x {
                must "../../../static-length>0 or ../../../compress-static-length>0";
                key "value if-name next-hop";
                unique "if-name next-hop s-flag";
                description
                  "Configure End.X type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  must "(../s-flag = 'false' and count(../../end-x[value=current()]) = 1) or (../s-flag='true' and not(../../end-x[value = current()][protected != current()/../protected]))";
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
                leaf if-name {
                  type leafref {
                    path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
                  }
                  description
                    "Interface name.";
                }
                leaf next-hop {
                  type inet:ipv6-address-no-zone;
                  description
                    "Nexthop address.";
                }
                leaf compress {
                 
                  type boolean;
                  must "(../compress = 'true' and (../../../../compress-block-length>0 or ../../../../compress-16) and (../../../../compress-static-length>0)) or ../compress = 'false'";
                  default "false";
                  description
                    "Enable/disable compress function.";
                }
                leaf s-flag {
                  type boolean;
                  default "false";
                  description
                    "Enable/disable the ability to associate an Opcode value with a set of adjacencies.";
                }
                leaf protected {
                  type boolean;
                  must "../protected = 'false' or ../../../../flex-algo = 0";
                  default "false";
                  description
                    "Enable/disable protected End.X.";
                }
              }
            }
            container end-x-psps {
              description
                "List of End.X psp type opcode configuration.";
              list end-x-psp {
                must "../../../static-length>0 or ../../../compress-static-length>0";
                key "value if-name next-hop";
                unique "if-name next-hop s-flag";
                description
                  "Configure End.X psp type opcode configuration.";
                leaf value {
                  type inet:ipv6-address-no-zone;
                  must "(../s-flag = 'false' and count(../../end-x-psp[value=current()]) = 1) or (../s-flag='true' and not(../../end-x-psp[value = current()][protected != current()/../protected]))";
                  description
                    "Opcode value. The opcode range is dynamically calculated based on the locator configuration.";
                }
                leaf if-name {
                  type leafref {
                    path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
                  }
                  description
                    "Interface name.";
                }
                leaf next-hop {
                  type inet:ipv6-address-no-zone;
                  description
                    "NextHop address.";
                }
                leaf compress {
                 
                  type boolean;
