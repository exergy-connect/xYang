                    }
                    leaf reply-node-address {
                      type inet:ipv6-address-no-zone;
                      description
                        "Reply node address detected by path MTU detection.";
                    }
                  }
                }
              }
            }
            container policy-association-groups {
              description
                "List of policy association groups in a candidate path.";
              list policy-association-group {
                key "group-id source-ip";
                max-elements 1;
                description
                  "Operational state of a policy association group in the candidate path.";
