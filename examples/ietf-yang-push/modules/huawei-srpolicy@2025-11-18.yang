                  type uint64;
                  description
                    "Latest period of IFIT update message.";
                }
                leaf igp-metric {
                  type uint32;
                  description
                    "IGP metric of segment list.";
                }
                leaf te-metric {
                  type uint32;
                  description
                    "TE metric of segment list.";
                }
                leaf delay-metric {
                  type uint32;
                  description
                    "Delay metric of segment list.";
                }
                leaf hop-counts {
                  type uint32;
                  description
                    "Hop counts of segment list.";
                }
                leaf path-mtu-detected-min-mtu {
                  type uint16;
                  description
                    "Minimum MTU detected by path MTU detection.";
                }
                leaf path-mtu-detected-reply-node-address {
                  type inet:ipv6-address-no-zone;
                  description
                    "Reply node address detected by path MTU detection.";
                }
                container path-mtu-detected-records {
                  description
