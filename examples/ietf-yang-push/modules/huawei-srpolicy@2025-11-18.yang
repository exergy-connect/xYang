                  description
                    "List of SIDs.";
                  list sid {
                    key "index";
                    max-elements 10;
                    description
                      "Operational data of SID.";
                    leaf index {
                      type uint32;
                      description
                        "Id.";
                    }
                    leaf value {
                      type inet:ipv6-address-no-zone;
                      description
                        "Val.";
                    }
                    leaf block-length {
                      type uint32;
                      description
                        "Block length.";
                    }
