                type string {
                  length "1..31";
                }
                description
                  "Segment list name.";
              }
              leaf preference {
                type uint32;
                description
                  "Candidate path preference.";
              }
              leaf discriminator {
                type uint32;
                description
                  "Candidate path discriminator.";
              }
