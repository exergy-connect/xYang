          type inet:ip-address-no-zone;
          description
            "SR Policy endpoint.";
        }
        leaf color {
          type uint32;
          description
            "SR Policy color.";
        }
        leaf allocation-success {
          type boolean;
          description
            "Whether binding SID allocation succeeds.";
        }
        leaf is-configured {
          type boolean;
          description
            "Whether the binding SID is a locally configured one.";
        }
        leaf dynamic-path-count {
          type uint32;
          description
            "Number of dynamically delivered candidate paths with the binding SID.";
        }
        container dynamic-candidate-paths {
          description
            "List of dynamic candidate paths.";
          list dynamic-candidate-path {
            key "distinguisher preference protocol-origin asn node-address";
            description
              "Statistics of dynamic candidate path.";
            leaf distinguisher {
              type uint32;
              description
                "Candidate path distinguisher.";
            }
            leaf preference {
              type uint32;
              description
                "Candidate path preference.";
            }
            leaf protocol-origin {
              type protocol-origin-type;
              description
                "Candidate path protocol origin.";
            }
            leaf asn {
              type uint32;
              description
                "Candidate path AS No.";
            }
            leaf node-address {
              type inet:ip-address-no-zone;
              description
                "Node address of a candidate path.";
            }
          }
        }
        container segment-list {
          description
            "Statistics of the segment list for the binding SID allocated within the SRLB range.";
          leaf distinguisher {
            type uint32;
            description
              "Candidate path distinguisher.";
          }
          leaf preference {
            type uint32;
            description
              "Candidate path preference.";
          }
          leaf protocol-origin {
            type protocol-origin-type;
            description
              "Candidate path protocol origin.";
          }
          leaf asn {
            type uint32;
            description
              "Candidate path AS No.";
          }
          leaf node-address {
            type inet:ip-address-no-zone;
            description
              "Candidate path node address.";
          }
          leaf segment-list-id {
            type uint32;
            description
              "Segment list ID.";
          }
        }
      }
    }
  }

  grouping constraints {
    description
      "List of SR Policy constraints.";
    leaf link-bandwidth-utilization {
      type uint8 {
        range "0..100";
      }
      description
        "Link bandwidth usage.";
    }
    leaf metric-type {
      type metric-type;
      description
        "Metric type.";
    }
    leaf max-igp-cumulation {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Maximum IGP cost of all hops on a path.";
    }
    leaf max-te-cumulation {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Maximum TE cost of all hops on a path.";
    }
    leaf max-hopcount-cumulation {
      type uint16 {
        range "1..32";
      }
      description
        "Maximum number of hops on a path.";
    }
    leaf max-delay-cumulation {
      type uint32 {
        range "1..60000000";
      }
      description
        "Maximum delay of all hops on a path.";
    }
    choice type {
      description
        "Administrative group constraint type.";
      case include-any {
        description
          "Include any specified administrative group.";
        leaf-list include-any-affinity-name {
          type leafref {
            path "/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping/te:attribute-name";
          }
          must "((/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping[te:attribute-name=current()]/te:bit-sequence>=0) and (/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping[te:attribute-name=current()]/te:bit-sequence<=31))";
          max-elements 32;
          description
            "Configure the include-any affinity.";
        }
      }
      case include-all {
        description
          "Include all specified administrative groups.";
        leaf-list include-all-affinity-name {
          type leafref {
            path "/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping/te:attribute-name";
          }
          must "((/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping[te:attribute-name=current()]/te:bit-sequence>=0) and (/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping[te:attribute-name=current()]/te:bit-sequence<=31))";
          max-elements 32;
          description
            "Configure the include-all affinity.";
        }
      }
    }
    leaf-list exclude-affinity-name {
      type leafref {
        path "/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping/te:attribute-name";
      }
      must "((/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping[te:attribute-name=current()]/te:bit-sequence>=0) and (/te:te/te:affinity-define/te:affinity-mappings/te:affinity-mapping[te:attribute-name=current()]/te:bit-sequence<=31)) and not ((../include-any-affinity-name = current()) or (../include-all-affinity-name = current()))";
      max-elements 32;
      description
        "Configure the exclude affinity.";
    }
    leaf constraint-path-name {
      type leafref {
        path "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path/srpolicy:name";
      }
      description
        "Name of a path constraint.";
    }
    leaf sid-selection {
      type sid-selection-type;
      description
        "SID selection criteria.";
    }
    container sid-algorithm {
      description
        "Configure SID algorithm.";
      leaf sid-algorithm-id {
        type uint8 {
          range "0 | 128..255";
        }
        description
          "Configure SID algorithm ID.";
      }
      leaf strict {
        when "../sid-algorithm-id";
        type boolean;
        default "false";
        description
          "Enable/disable strict mode.";
      }
      leaf path-computation-mode {
        when "../sid-algorithm-id";
        type path-computation-mode-type;
        must "((../path-computation-mode='flex-algo' and ../sid-algorithm-id >= 128 and ../sid-algorithm-id <= 255 and not (../../exclude-affinity-name or ../../include-any-affinity-name or ../../include-all-affinity-name)) or (../path-computation-mode='sid-filter'))";
        default "sid-filter";
        description
          "Configure path computation mode.";
      }
    }
  }

  grouping disjoint-association-group {
    description
      "Disjoint association groups for PCE path computation.";
    container disjoint-paths {
      description
        "List of disjoint paths.";
      list disjoint-path {
        key "group-id source-ip";
        max-elements 1;
        description
          "Configure a disjoint path.";
        leaf group-id {
          type uint16 {
            range "1..65534";
          }
          description
            "ID of a disjoint association group.";
        }
        leaf source-ip {
          type inet:ip-address;
          description
            "Source IP address of a disjoint association group.";
        }
        leaf type {
          type disjointness-type;
          mandatory true;
          description
            "Type of a disjoint association group.";
        }
        leaf shortest {
          type boolean;
          default "false";
          description
            "Enable/disable preferential computation of the shortest path.";
        }
        leaf strict {
          type boolean;
          default "false";
          description
            "Enable/disable the function of calculating strictly disjoint paths.";
        }
        leaf of-code {
          type of-code;
          must "(../strict='false')";
          description
            "Objective function code.";
        }
      }
    }
  }

  grouping policy-association-group {
    description
      "Policy association groups for PCE path computation.";
    container policy-association-groups {
      description
        "List of policy association groups.";
      list policy-association-group {
        key "group-id source-ip";
        max-elements 1;
        description
          "Configure a policy association group.";
        leaf group-id {
          type uint16 {
            range "1..65534";
          }
          description
            "ID of a policy association group.";
        }
        leaf source-ip {
          type inet:ip-address;
          description
            "Source IP address of a policy association group.";
        }
        leaf policy-parameters {
          type string {
            length "1..255";
          }
          description
            "Policy association group parameters.";
        }
      }
    }
  }

  grouping bidirectional-association-group {
    description
      "Bidirectional association group for PCE path computation.";
    container bidirectional-association-group {
      presence "Bidirectional association group.";
      description
        "Configure a bidirectional association group.";
      leaf group-id {
        type uint16 {
          range "1..65534";
        }
        mandatory true;
        description
          "ID of a bidirectional association group.";
      }
      leaf source-ip {
        type inet:ip-address;
        mandatory true;
        description
          "Source IP address of a bidirectional association group.";
      }
      leaf co-routed {
        type boolean;
        default "false";
        description
          "Enable/disable co-routed bidirectional path.";
      }
    }
  }

  container srpolicy {
    description
      "Configure SR Policy parameters.";
    container global {
      description
        "Configure SR Policy global parameters.";
      leaf cpu-overload-control {
        type boolean;
        default "true";
        description
          "Enable/disable CPU overload control.";
      }
    }
    container attribute-templates {
      description
        "List of SR Policy template attribute.";
      list attribute-template {
        key "id";
        description
          "Configure SR Policy template attribute.";
        leaf id {
          type uint32 {
            range "1..4294967269";
          }
          description
            "The template ID.";
        }
        leaf description {
          type string {
            length "1..242";
          }
          description
            "The template description.";
        }
        leaf bfd-enable {
          type policy-bfd-enable-type;
          default "not-configured";
          description
            "The template BFD flag.";
        }
        leaf bfd-bypass {
          type policy-bfd-bypass-type;
          default "not-configured";
          description
            "The template BFD bypass flag.";
        }
        leaf bfd-slice-inherit-match {
          type template-bfd-slice-inherit-type;
          description
            "Inheritance type (for the network slice's match mode) of BFD detection packets configured for the SR Policy template.";
        }
        leaf hsb-enable {
          type enable-3types;
          default "not-configured";
          description
            "The template hot standby flag.";
        }
        leaf traffic-statistics-enable {
          type enable-3types;
          default "not-configured";
          description
            "The template traffic statistics flag.";
        }
        leaf path-mtu-detect {
          type path-mtu-detect-type;
          description
            "Template path MTU detection flag.";
        }
        leaf path-verification-enable {
          type path-verification-type;
          default "not-configured";
          description
            "The template path verification flag.";
        }
      }
    }
    container attribute-template-infos {
      config false;
      description
        "List of SR Policy attribute template informations.";
      list attribute-template-info {
        key "id";
        description
          "Operational state of SR Policy attribute template.";
        leaf id {
          type uint32;
          description
            "The template ID.";
        }
        leaf description {
          type string {
            length "1..242";
          }
          description
            "The template description.";
        }
        leaf bfd-enable {
          type policy-bfd-enable-type;
          description
            "Enable/disable BFD.";
        }
        leaf bfd-bypass {
          type policy-bfd-bypass-type;
          description
            "Enable/disable BFD bypass.";
        }
        leaf bfd-slice-inherit-match {
          type template-bfd-slice-inherit-type;
          description
            "Inheritance type (for the network slice's match mode) of BFD detection packets configured for the SR Policy template.";
        }
        leaf hsb-enable {
          type enable-3types;
          description
            "Enable/disable hot standby.";
        }
        leaf path-mtu-detect {
          type path-mtu-detect-type;
          description
            "Enable/disable path MTU detection.";
        }
        leaf path-verification-enable {
          type path-verification-type;
          description
            "Enable/disable path verification.";
        }
        leaf traffic-statistics-enable {
          type enable-3types;
          description
            "Enable/disable traffic statistics.";
        }
        leaf configuratin-path-refcnt {
          type uint32;
          description
            "The configuration path reference count.";
        }
        leaf sr-configuration-path-refcnt {
          type uint32;
          description
            "The SR-MPLS TE Policy configuration path reference count.";
        }
        leaf srv6-configuration-path-refcnt {
          type uint32;
          description
            "The SRv6 TE Policy configuration path reference count.";
        }
        leaf bgp-path-refcnt {
          type uint32;
          description
            "The BGP path reference count.";
        }
        leaf sr-bgp-path-refcnt {
          type uint32;
          description
            "The SR-MPLS TE Policy BGP path reference count.";
        }
        leaf srv6-bgp-path-refcnt {
          type uint32;
          description
            "The SRv6 TE Policy BGP path reference count.";
        }
        leaf odn-template-refcnt {
          type uint32;
          description
            "The ODN template reference count.";
        }
        leaf sr-odn-template-refcnt {
          type uint32;
          description
            "The SR-MPLS TE Policy ODN template reference count.";
        }
        leaf srv6-odn-template-refcnt {
          type uint32;
          description
            "The SRv6 TE Policy ODN template reference count.";
        }
        leaf sr-pag-refcnt {
          type uint32;
          description
            "The SR-MPLS TE Policy policy association group reference count.";
        }
        leaf srv6-pag-refcnt {
          type uint32;
          description
            "The SRv6 TE Policy policy association group reference count.";
        }
      }
    }
    container constraint-paths {
      description
        "List of SR Policy path constraints.";
      list constraint-path {
        key "name";
        description
          "Configure an SR Policy path constraint.";
        leaf name {
          type string {
            length "1..31";
          }
          description
            "Name of a path constraint.";
        }
        leaf hop-type {
          type constraint-path-hop-type;
          default "ipv4";
          description
            "Constraint path type.";
        }
        container hops {
          description
            "List of per-hop information in a path constraint.";
          list hop {
            must "../../hop-type = 'ipv4'";
            key "index";
            unique "ipv4-address";
            max-elements 32;
            description
              "Configure a hop in a path constraint.";
            leaf index {
              type uint32 {
                range "1..4294967295";
              }
              description
                "Hop index.";
            }
            leaf ipv4-address {
              type inet:ipv4-address-no-zone;
              mandatory true;
              description
                "IPv4 address.";
            }
            leaf ipv4-constraint-type {
              type constraint-type;
              default "include-strict";
              description
                "Type of the path constraint of the IPv4 address type.";
            }
          }
        }
        container ipv6-hops {
          description
            "List of per-hop information in a path constraint.";
          list ipv6-hop {
            must "../../hop-type = 'ipv6'";
            key "index";
            unique "ipv6-address";
            max-elements 32;
            description
              "Configure a hop in a path constraint.";
            leaf index {
              type uint32 {
                range "1..4294967295";
              }
              description
                "Hop index.";
            }
            leaf ipv6-address {
              type inet:ipv6-address-no-zone;
              mandatory true;
              description
                "IPv6 address.";
            }
            leaf ipv6-constraint-type {
              type constraint-type;
              default "include-strict";
              description
                "Type of the path constraint of the IPv6 address type.";
            }
          }
        }
      }
    }
    container constraint-templates {
      description
        "List of SR Policy constraint templates.";
      list constraint-template {
        must "(setup-priority>=hold-priority)";
        key "name";
        description
          "Configure an SR Policy constraint template.";
        leaf name {
          type string {
            length "1..31";
          }
          description
            "Name of a constraint template.";
        }
        leaf ct0-bandwidth {
          type uint64 {
            range "1..6400000000";
          }
          units "kbit/s";
          description
            "CT0 bandwidth.";
        }
        leaf setup-priority {
          type uint8 {
            range "0..7";
          }
          default "7";
          description
            "SR Policy setup priority.";
        }
        leaf hold-priority {
          type uint8 {
            range "0..7";
          }
          default "7";
          description
            "SR Policy holding priority.";
        }
        uses constraints {
          refine "metric-type" {
            default "te";
          }
          refine "sid-selection" {
            default "unprotected-preferred";
          }
        }
        uses disjoint-association-group;
        uses policy-association-group;
      }
    }
  }

  augment "/ni:network-instance/ni:instances/ni:instance/srv6:srv6" {
    description
      "Augment for Segment Routing Policy.";
    container srpolicy {
      when "../srv6:enable='true'";
      description
        "Configure SR Policy parameters.";
      uses srv6-policy-attributes;
      uses srv6-policys;
      container policy-traffic-statistics {
        config false;
        description
          "List of traffic statistics for SR Policies.";
        list policy-traffic-statistic {
          key "endpoint color";
          description
            "Traffic statistics for an SR Policy.";
          leaf endpoint {
            type inet:ip-address-no-zone;
            description
              "Destination address of an SR Policy.";
          }
          leaf color {
            type uint32 {
              range "0..4294967295";
            }
            description
              "Color of an SR Policy.";
          }
          leaf name {
           
            type string {
              length "1..255";
            }
            description
              "Policy name.";
          }
          leaf binding-sid {
           
            type sid-value-type;
            description
              "Preferred binding SID of an SR Policy.";
          }
          leaf tunnel-id {
            type uint32;
            description
              "Tunnel ID of an SR Policy.";
          }
          leaf flow-period {
            type uint32 {
              range "0..4294967295";
            }
            units "s";
            description
              "Traffic statistics collection period.";
          }
          leaf last-period-byte-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte/s";
            description
              "Byte rate in the latest period.";
          }
          leaf last-period-pkt-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "pps";
            description
              "Packet rate in the latest period.";
          }
          leaf last-period-bit-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "bit/s";
            description
              "Bit rate in the latest period.";
          }
          leaf display-interval {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "s";
            description
              "Interval between two queries.";
          }
          leaf interval-byte-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte/s";
            description
              "Byte rate between two queries.";
          }
          leaf interval-pkt-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "pps";
            description
              "Packet rate between two queries.";
          }
          leaf interval-bit-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "bit/s";
            description
              "Bit rate between two queries.";
          }
          leaf total-byte {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte";
            description
              "Total number of transmitted bytes.";
          }
          leaf total-packet {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "packet";
            description
              "Total number of transmitted packets.";
          }
          leaf compensated-last-period-byte-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte/s";
            description
              "Compensated byte rate in the latest period.";
          }
          leaf compensated-last-period-bit-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "bit/s";
            description
              "Compensated bit rate in the latest period.";
          }
          leaf compensated-interval-byte-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte/s";
            description
              "Compensated byte rate between two queries.";
          }
          leaf compensated-interval-bit-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "bit/s";
            description
              "Compensated bit rate between two queries.";
          }
          leaf compensated-total-byte {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte";
            description
              "Compensated total number of transmitted bytes.";
          }
        }
      }
      container list-traffic-statistics {
        config false;
        description
          "List of traffic statistics for segment lists.";
        list list-traffic-statistic {
          key "segment-list-id";
          description
            "Traffic statistics for a segment list.";
          leaf segment-list-id {
            type uint32 {
              range "1..4294967295";
            }
            description
              "Segment list ID.";
          }
          leaf xc-index {
            type uint32;
            description
              "XC index.";
          }
          leaf path-id {
            type uint32;
            description
              "The path id uniquely identifies a segment list within the context of a candidate path, but only used for PCEP delivered segment lists, the value will be set to 0 when a segment list is delivered by BGP or configuration.";
          }
          leaf policy-name {
           
            type string {
              length "1..255";
            }
            description
              "Policy name.";
          }
          leaf endpoint {
           
            type inet:ip-address-no-zone;
            description
              "Destination address of an SR Policy.";
          }
          leaf color {
           
            type uint32 {
              range "0..4294967295";
            }
            description
              "Color of an SR Policy.";
          }
          leaf binding-sid {
           
            type sid-value-type;
            description
              "Preferred binding SID of an SR Policy.";
          }
          leaf tunnel-id {
            type uint32;
            description
              "Tunnel ID of an SR Policy.";
          }
          leaf preference {
            type uint32 {
              range "0..4294967295";
            }
            description
              "Preference of a candidate path.";
          }
          leaf protocol-origin {
            type protocol-origin-type;
            description
              "Protocol origin of a candidate path.";
          }
          leaf asn {
            type uint32;
            description
              "AS number.";
          }
          leaf node-address {
            type inet:ip-address-no-zone;
            description
              "Node address.";
          }
          leaf discriminator {
            type uint32 {
              range "0..4294967295";
            }
            description
              "Discriminator of a candidate path.";
          }
          leaf path-type {
            type path-type;
            description
              "Type of a candidate path.";
          }
          container sids {
            description
              "List of SIDs.";
            list sid {
              key "index";
              max-elements 10;
              description
                "Operational data of SID.";
              leaf index {
                type uint32 {
                  range "0..4294967295";
                }
                description
                  "SID index.";
              }
              leaf value {
                type sid-value-type;
                description
                  "SID value.";
              }
            }
          }
          leaf flow-period {
            type uint32 {
              range "0..4294967295";
            }
            units "s";
            description
              "Traffic statistics collection period.";
          }
          leaf last-period-byte-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte/s";
            description
              "Byte rate in the latest period.";
          }
          leaf last-period-pkt-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "pps";
            description
              "Packet rate in the latest period.";
          }
          leaf last-period-bit-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "bit/s";
            description
              "Bit rate in the latest period.";
          }
          leaf display-interval {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "s";
            description
              "Interval between two queries.";
          }
          leaf interval-byte-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte/s";
            description
              "Byte rate between two queries.";
          }
          leaf interval-pkt-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "pps";
            description
              "Packet rate between two queries.";
          }
          leaf interval-bit-rate {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "bit/s";
            description
              "Bit rate between two queries.";
          }
          leaf total-byte {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "Byte";
            description
              "Total number of transmitted bytes.";
          }
          leaf total-packet {
            type uint64 {
              range "0..18446744073709551615";
            }
            units "packet";
            description
              "Total number of transmitted packets.";
          }
          leaf no-resource-flag {
            type boolean;
