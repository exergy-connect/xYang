  grouping auto-bandwidth-adjustment-info {
    description
      "SR Policy automatic bandwidth adjustment information.";
    container auto-bandwidth {
      description
        "Statistics of auto-bandwidth adjustment in an SR-MPLS TE Policy.";
      leaf auto-bandwidth-enable {
        type boolean;
        description
          "Whether automatic bandwidth adjustment is enabled for SR-MPLS TE Policy.";
      }
      leaf current-bandwidth {
        type uint64;
        units "kbit/s";
        description
          "Bandwidth allocated to the current SR-MPLS TE Policy.";
      }
      leaf sample-interval {
        type uint32;
        units "s";
        description
          "Interval at which the traffic rate of an SR-MPLS TE Policy's outbound interface is sampled.";
      }
      leaf adjust-launch-timer-remain {
        type uint32;
        units "s";
        description
          "Remaining time in the discretization timer set for the automatic bandwidth adjustment timer.";
      }
      leaf sample-launch-timer-remain {
        type uint32;
        units "s";
        description
          "Remaining time in the discretization timer set for the automatic bandwidth sampling timer.";
      }
      leaf min-bandwidth {
        type uint64;
        units "kbit/s";
        description
          "Minimum bandwidth supported by automatic bandwidth adjustment.";
      }
      leaf max-bandwidth {
        type uint64;
        units "kbit/s";
        description
          "Maximum bandwidth supported by automatic bandwidth adjustment.";
      }
      leaf up-threshold-percent {
        type uint8;
        description
          "Relative bandwidth change threshold for triggering upward bandwidth adjustment.";
      }
      leaf up-threshold-percent-min-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for upward bandwidth adjustment to take effect.";
      }
      leaf up-threshold-absolute-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering upward bandwidth adjustment.";
      }
      leaf down-threshold-percent {
        type uint8;
        description
          "Relative bandwidth change threshold for triggering downward bandwidth adjustment.";
      }
      leaf down-threshold-percent-min-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for downward bandwidth adjustment to take effect.";
      }
      leaf down-threshold-absolute-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering downward bandwidth adjustment.";
      }
      leaf up-adjustment-frequency {
        type uint32;
        units "s";
        description
          "Interval at which upward automatic bandwidth adjustment is performed.";
      }
      leaf up-adjustment-timer-remain {
        type uint32;
        units "s";
        description
          "Remaining time for the next upward automatic bandwidth adjustment.";
      }
      leaf up-sample-count {
        type uint8;
        description
          "Number of sampling times that the sampled value is greater than the currently allocated bandwidth.";
      }
      leaf up-collect-max-bw {
        type uint64;
        units "kbit/s";
        description
          "Maximum bandwidth of upward bandwidth adjustment collected in the previous bandwidth sampling period.";
      }
      leaf down-adjustment-frequency {
        type uint32;
        units "s";
        description
          "Interval at which downward automatic bandwidth adjustment is performed.";
      }
      leaf down-adjustment-timer-remain {
        type uint32;
        units "s";
        description
          "Remaining time for the next downward automatic bandwidth adjustment.";
      }
      leaf down-sample-count {
        type uint8;
        description
          "Number of sampling times that the sampled value is less than the currently allocated bandwidth.";
      }
      leaf down-collect-max-bw {
        type uint64;
        units "kbit/s";
        description
          "Maximum bandwidth of downward bandwidth adjustment collected in the previous bandwidth sampling period.";
      }
      leaf overflow-limit {
        type uint8;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast upward bandwidth adjustment meets the absolute bandwidth change threshold.";
      }
      leaf overflow-threshold-absolute-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering fast upward bandwidth adjustment.";
      }
      leaf overflow-sample-count {
        type uint8;
        description
          "Number of sampling times that the sampling value meets the absolute threshold change within the fast upward bandwidth adjustment period.";
      }
      leaf overflow-percent-limit {
        type uint8;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast upward bandwidth adjustment meets the relative bandwidth change threshold.";
      }
      leaf overflow-threshold-percent {
        type uint8;
        description
          "Relative bandwidth change threshold for triggering fast upward bandwidth adjustment.";
      }
      leaf overflow-percent-sample-count {
        type uint8;
        description
          "Number of sampling times that the sampling value meets the relative threshold change within the fast upward bandwidth adjustment period.";
      }
      leaf overflow-threshold-percent-min-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for fast upward bandwidth adjustment to take effect.";
      }
      leaf overflow-collect-max-bw {
        type uint64;
        units "kbit/s";
        description
          "Maximum bandwidth that meets the change threshold and is collected in the fast upward bandwidth adjustment period.";
      }
      leaf underflow-limit {
        type uint8;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast downward bandwidth adjustment meets the absolute bandwidth change threshold.";
      }
      leaf underflow-threshold-absolute-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering fast downward bandwidth adjustment.";
      }
      leaf underflow-sample-count {
        type uint8;
        description
          "Number of sampling times that the sampling value meets the absolute threshold change within the fast downward bandwidth adjustment period.";
      }
      leaf underflow-percent-limit {
        type uint8;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast downward bandwidth adjustment meets the relative bandwidth change threshold.";
      }
      leaf underflow-threshold-percent {
        type uint8;
        description
          "Relative bandwidth change threshold for triggering fast downward bandwidth adjustment.";
      }
      leaf underflow-percent-sample-count {
        type uint8;
        description
          "Number of sampling times that the sampling value meets the relative threshold change within the fast downward bandwidth adjustment period.";
      }
      leaf underflow-threshold-percent-min-bw {
        type uint64;
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for fast downward bandwidth adjustment to take effect.";
      }
      leaf underflow-collect-max-bw {
        type uint64;
        units "kbit/s";
        description
          "Maximum bandwidth that meets the change threshold and is collected in the fast downward bandwidth adjustment period.";
      }
    }
  }

  grouping auto-bandwidth-adjustment {
    description
      "SR Policy automatic bandwidth adjustment configuration.";
    container auto-bandwidth-adjustment {
      presence "Enable auto-bandwidth adjustment.";
      description
        "Configure auto-bandwidth adjustment parameters.";
      leaf adjustment-interval {
        type uint32 {
          range "300..604800";
        }
        units "s";
        default "86400";
        description
          "Interval of automatic bandwidth adjustment.";
      }
      leaf down-adjustment-interval {
        type uint32 {
          range "300..604800";
        }
        units "s";
        description
          "Downward adjustment for the interval of automatic bandwidth adjustment.";
      }
      leaf min-bandwidth {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        must "(../max-bandwidth>=../min-bandwidth)";
        description
          "Minimum bandwidth supported by automatic bandwidth adjustment.";
      }
      leaf max-bandwidth {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Maximum bandwidth supported by automatic bandwidth adjustment.";
      }
      leaf threshold-percent {
        type uint8 {
          range "1..100";
        }
        default "5";
        description
          "Relative bandwidth change threshold for triggering upward bandwidth adjustment.";
      }
      leaf threshold-percent-min-bw {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for upward bandwidth adjustment to take effect.";
      }
      leaf threshold-absolute-bw {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering upward bandwidth adjustment.";
      }
      leaf down-threshold-percent {
        type uint8 {
          range "1..100";
        }
        description
          "Relative bandwidth change threshold for triggering downward bandwidth adjustment.";
      }
      leaf down-threshold-percent-min-bw {
        when "../down-threshold-percent";
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for downward bandwidth adjustment to take effect.";
      }
      leaf down-threshold-absolute-bw {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering downward bandwidth adjustment.";
      }
      leaf overflow-threshold-absolute-bw {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering fast upward bandwidth adjustment.";
      }
      leaf overflow-count {
        when "../overflow-threshold-absolute-bw";
        type uint8 {
          range "1..31";
        }
        mandatory true;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast upward bandwidth adjustment meets the absolute bandwidth change threshold.";
      }
      leaf overflow-threshold-percent {
        type uint8 {
          range "1..100";
        }
        description
          "Relative bandwidth change threshold for triggering fast upward bandwidth adjustment.";
      }
      leaf overflow-percent-count {
        when "../overflow-threshold-percent";
        type uint8 {
          range "1..31";
        }
        mandatory true;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast upward bandwidth adjustment meets the relative bandwidth change threshold.";
      }
      leaf overflow-threshold-percent-min-bw {
        when "../overflow-threshold-percent";
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for fast upward bandwidth adjustment to take effect.";
      }
      leaf underflow-threshold-absolute-bw {
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold for triggering fast downward bandwidth adjustment.";
      }
      leaf underflow-count {
        when "../underflow-threshold-absolute-bw";
        type uint8 {
          range "1..31";
        }
        mandatory true;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast downward bandwidth adjustment meets the absolute bandwidth change threshold.";
      }
      leaf underflow-threshold-percent {
        type uint8 {
          range "1..100";
        }
        description
          "Relative bandwidth change threshold for triggering fast downward bandwidth adjustment.";
      }
      leaf underflow-percent-count {
        when "../underflow-threshold-percent";
        type uint8 {
          range "1..31";
        }
        mandatory true;
        description
          "Number of consecutive sampling times that the sampling value required for triggering fast downward bandwidth adjustment meets the relative bandwidth change threshold.";
      }
      leaf underflow-threshold-percent-min-bw {
        when "../underflow-threshold-percent";
        type uint64 {
          range "1..6400000000";
        }
        units "kbit/s";
        description
          "Absolute bandwidth change threshold that enables the relative threshold for fast downward bandwidth adjustment to take effect.";
      }
    }
  }

  grouping bfd {
    description
      "SR Policy BFD configuration.";
    container bfd {
      description
        "Configure SR Policy BFD.";
      leaf enable {
        type bfd-enable-type;
        default "disable";
        description
          "Enable seamless-bfd for all SR Policies.";
      }
      leaf bypass {
        type bfd-bypass-type;
        default "bypass";
        description
          "Enable BFD bypass for all SR policies.";
      }
      leaf min-tx {
        type uint32 {
          range "1..4294967295";
        }
        units "ms";
        default "10";
        description
          "Minimum interval for sending seamless-bfd packets to the peer end.";
      }
      leaf min-rx {
        type uint32 {
          range "1..4294967295";
        }
        units "ms";
        default "10";
        description
          "Minimum interval for receiving seamless-bfd packets from the peer end.";
      }
      leaf multi-num {
        type uint32 {
          range "3..50";
        }
        default "3";
        description
          "Local detection multiplier.";
      }
      leaf backup-min-tx {
        type uint32 {
          range "1..4294967295";
        }
        units "ms";
        description
          "Minimum interval for sending seamless-bfd packets to the peer end over the backup candidate path.";
      }
      leaf backup-multi-num {
        type uint32 {
          range "3..50";
        }
        description
          "Local detection multiplier over the backup candidate path.";
      }
      leaf switch-delay {
        type uint32 {
          range "1..2592000";
        }
        units "s";
        description
          "The BFD switching delay.";
      }
      leaf slice-inherit-match {
        type boolean;
        default "false";
        description
          "Enable/disable the inheritance type (for the network slice's match mode) of BFD detection packets configured for the global configuration.";
      }
      leaf backup-initial-up-delay {
        type uint32 {
          range "1..600000";
        }
        units "ms";
        description
          "Delay after which BFD goes up for the backup path.";
      }
    }
  }

  grouping global-attributes {
    description
      "SR Policy global configuration.";
    leaf switch-delay {
      type uint32 {
        range "0..600000";
      }
      units "ms";
      default "5000";
      description
        "MBB switch delay time.";
    }
    leaf delete-delay {
      type uint32 {
        range "0..600000";
      }
      units "ms";
      default "20000";
      description
        "MBB delete delay time.";
    }
    leaf hsb-enable {
      type boolean;
      default "false";
      description
        "Enable/disable hot standby.";
    }
    leaf traffic-statistics-enable {
      type boolean;
      default "false";
      description
        "Enable/disable traffic statistics collection.";
    }
    leaf bgp-ls-enable {
      type boolean;
      default "false";
      description
        "Enable/disable BGP-LS.";
    }
    leaf path-mtu-detect {
      type path-mtu-detect-type;
      default "disable";
      description
        "Path MTU detection.";
    }
    leaf path-mtu-period-detect {
      type boolean;
      default "true";
      description
        "Enable/disable periodic path MTU detection.";
    }
    leaf path-mtu-period-detect-interval {
      when "(../path-mtu-period-detect='true')";
      type uint32 {
        range "60..1296000";
      }
      units "s";
      default "300";
      description
        "Interval of periodic path MTU detection.";
    }
    leaf path-verification {
      type boolean;
      default "false";
      description
        "Enable/disable path verification.";
    }
    leaf path-verification-specified-sid {
      when "(../path-verification='true')";
      type boolean;
      default "false";
      description
        "Enable/disable path verification for specified-sid.";
    }
    leaf suppress-flapping {
      type boolean;
      default "true";
      description
        "Enable/disable suppress flapping.";
    }
    leaf policy-threshold-upper {
      type uint32 {
        range "2..100";
      }
      must "(../policy-threshold-upper>../policy-threshold-lower)";
      default "80";
      description
        "SR Policy threshold upper limit.";
    }
    leaf policy-threshold-lower {
      type uint32 {
        range "1..99";
      }
      default "75";
      description
        "SR Policy threshold lower limit.";
    }
    leaf list-threshold-upper {
      type uint32 {
        range "2..100";
      }
      must "(../list-threshold-upper>../list-threshold-lower)";
      default "80";
      description
        "Segment List threshold upper limit.";
    }
    leaf list-threshold-lower {
      type uint32 {
        range "1..99";
      }
      default "75";
      description
        "Segment List threshold lower limit.";
    }
    leaf auto-bandwidth-sample-interval {
      type uint32 {
        range "60..604800";
      }
      units "s";
      description
        "Traffic rate sampling interval.";
    }
    leaf auto-bandwidth-enable {
      type boolean;
      default "false";
      description
        "Enable/disable automatic bandwidth adjustment for SR Policy.";
    }
    leaf pcep-lsp-identifiers-report {
      type boolean;
      default "false";
      description
        "Enable/disable SR Policy report LSP identifiers to PCEP.";
    }
    leaf metric-inherit-type {
      type global-inherit-mode;
      description
        "Metric type inherited by SR Policy.";
    }
    leaf list-reverse-bsid-switch-delay {
      type uint32 {
        range "0..600000";
      }
      units "ms";
      default "5000";
      description
        "Switching delay for the reverse binding SIDs in segment lists.";
    }
    leaf list-bsid-delete-delay {
      type uint32 {
        range "0..600000";
      }
      units "ms";
      default "20000";
      description
        "Deletion delay for the binding SIDs in segment lists.";
    }
    leaf list-reverse-xsid-switch-delay {
      type uint32 {
        range "0..600000";
      }
      units "ms";
      default "5000";
      description
        "Switching delay for the reverse XSIDs in segment lists.";
    }
    leaf list-xsid-delete-delay {
      type uint32 {
        range "0..600000";
      }
      units "ms";
      default "20000";
      description
        "Deletion delay for the XSIDs in segment lists.";
    }
    leaf segment-list-delete-hold {
      type boolean;
      default "false";
      description
        "Enable/disable the function to hold the deleted segment lists when new segment lists are all down.";
    }
    leaf dual-fed {
      type dual-fed-type;
      default "disable";
      description
        "Enable/Disable the dual-fed function for an SR Policy.";
    }
    leaf bsid-dynamic-specified-encaps-mode {
      type boolean;
      default "false";
      description
        "Enable/disable the dynamic specification of a binding SID encapsulation mode.";
    }
    uses bfd;
    container compute-types {
      description
        "List of different types of computation sources.";
      list compute-type {
        key "type";
        ordered-by user;
        description
          "Configure a computation source type.";
        leaf type {
          type global-compute-type;
          description
            "Computation source type.";
        }
      }
    }
  }

  grouping srv4-segment-lists {
    description
      "Global segment lists.";
    container segment-lists {
      description
        "List of global segment lists.";
      list segment-list {
        key "name";
        description
          "Configure a global segment list.";
        leaf name {
          type string {
            length "1..31";
          }
          description
            "Global segment list name.";
        }
        container segments {
          description
            "List of segments in a global segment list.";
          list segment {
            key "index";
            max-elements 10;
            description
              "Configure a segment in a global segment list.";
            leaf index {
              type uint32 {
                range "0..4294967295";
              }
              description
                "The segment index.";
            }
            choice type {
              mandatory true;
              description
                "The segment type.";
              case segment-type-1 {
                description
                  "The segment is declared by MPLS label.";
                leaf sid-value-1 {
                  type uint32 {
                    range "16..1048575";
                  }
                  description
                    "MPLS label value.";
                }
              }
            }
          }
        }
      }
    }
  }

  grouping srv6-segment-lists {
    description
      "Global segment lists.";
    container segment-lists {
      description
        "List of global segment lists.";
      list segment-list {
        key "name";
        description
          "Configure a global segment list.";
        leaf name {
          type string {
            length "1..31";
          }
          description
            "Global segment list name.";
        }
        container segments {
          description
            "List of segments in a global segment list.";
          list segment {
            key "index";
            max-elements 10;
            description
              "Configure a segment in a global segment list.";
            leaf index {
              type uint32 {
                range "0..4294967295";
              }
              description
                "The segment index.";
            }
            choice type {
              mandatory true;
              description
                "The segment type.";
              case segment-type-2 {
                description
                  "The segment is declared by SRv6 SID value.";
                leaf sid-value-2 {
                  type inet:ipv6-address-no-zone;
                  mandatory true;
                  description
                    "IPv6 value.";
                }
                choice compress-type {
                  description
                    "Type of a compressed SID of SRv6 TE Policy.";
                  case compress-32 {
                    description
                      "32-bit compressed SID of SRv6 TE Policy.";
                    leaf block-length {
                      type uint32 {
                        range "4..88";
                      }
                      must "((../block-length) mod 4 = 0)";
                      description
                        "Block length of a 32-bit compressed SID.";
                    }
                  }
                  case compress-16 {
                    description
                      "16-bit compressed SID of SRv6 TE Policy.";
                    leaf compress-16-block-length {
                      type uint32 {
                        range "16..76";
                      }
                      must "((../compress-16-block-length) mod 4 = 0)";
                      description
                        "Block length of a 16-bit compressed SID.";
                    }
                    leaf node-length {
                      when "../compress-16-block-length";
                      type uint32 {
                        range "0..16";
                      }
                      must "((../node-length) mod 16 = 0 and not((../node-length = 0) and (../verification = 'true')))";
                      mandatory true;
                      description
                        "Length of the Node ID field.";
                    }
                    leaf function-length {
                      when "../compress-16-block-length";
                      type uint32 {
                        range "0..16";
                      }
                      must "((../function-length) mod 16 = 0) and ((../node-length) + (../function-length) = 16)";
                      mandatory true;
                      description
                        "Length of the Function ID field.";
                    }
                    leaf compress-sid-flavor {
                      when "../compress-16-block-length";
                      type compress-flavor-type;
                      description
                        "Flavor of a 16-bit compressed SID.";
                    }
                  }
                }
                leaf verification {
                  type boolean;
                  default "false";
                  description
                    "Enable/disable verification of SID.";
                }
              }
            }
          }
        }
      }
    }
  }

  grouping srv6-policy-attributes {
    description
      "Grouping containing attributes applicable to all SR policies.";
    container policy-attributes {
      description
        "Configure attributes for all SR policies.";
      uses global-attributes;
      leaf locator {
       
       
        type leafref {
          path "/ni:network-instance/ni:instances/ni:instance/srv6:srv6/srv6:locators/srv6:locator/srv6:name";
        }
        status deprecated;
        description
          "Locator Name. The node locator is deprecated. You are advised to use the node locators.";
      }
      container locators {
        description
          "List of locators.";
        list locator {
          key "name";
          max-elements 2;
          description
            "Configure a locator.";
          leaf name {
            type leafref {
              path "/ni:network-instance/ni:instances/ni:instance/srv6:srv6/srv6:locators/srv6:locator/srv6:name";
            }
            description
              "Locator Name.";
          }
        }
      }
      uses srv6-segment-lists;
      container policy-association-groups {
        description
          "List of policy association groups.";
        list policy-association-group {
          key "group-id source-ip";
          description
            "Configure a policy association group.";
          leaf group-id {
            type uint16 {
              range "1..65534";
            }
            description
              "ID of a policy association group.";
          }
          leaf source-ip {
            type inet:ip-address;
            description
              "Source IP address of a policy association group.";
          }
          leaf attribute-template-id {
            type leafref {
              path "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template/srpolicy:id";
            }
            description
              "Attribute template ID.";
          }
        }
      }
      container srv6-odn-templates {
        description
          "List of SRv6 TE Policy ODN templates.";
        list srv6-odn-template {
          key "color";
          description
            "Configure an SRv6 TE Policy ODN template.";
          leaf color {
            type uint32 {
              range "1..4294967295";
            }
            description
              "SRv6 TE Policy ODN color.";
          }
          container compute-types {
            description
              "List of different types of computation sources.";
            list compute-type {
              key "type";
              ordered-by user;
              description
                "Configure a computation source type for an SRv6 TE policy ODN template.";
              leaf type {
                type global-compute-type;
                description
                  "Computation source type.";
              }
            }
          }
          leaf constraint-template-name {
            type leafref {
              path "/srpolicy:srpolicy/srpolicy:constraint-templates/srpolicy:constraint-template/srpolicy:name";
            }
            description
              "Name of a constraint template.";
          }
          leaf attribute-template-id {
            type leafref {
              path "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template/srpolicy:id";
            }
            description
              "Attribute template ID.";
          }
          leaf restrict-ipv6-prefix {
            type leafref {
              path "/rtp:routing-policy/rtp:ipv6-prefix-filters/rtp:ipv6-prefix-filter/rtp:name";
            }
            description
              "Specifies the IPv6 filtering policy to be applied to the SRv6 TE Policy ODN template. By default, no such policy is specified.";
          }
          container candidate-paths {
            description
              "List of candidate paths in an SRv6 TE Policy ODN template.";
            list candidate-path {
              key "preference";
              max-elements 64;
              description
                "Configure a candidate path.";
              leaf preference {
                type uint32 {
                  range "1..65535";
                }
                description
                  "Candidate path preference.";
              }
              uses constraints {
                refine "constraint-path-name" {
                  must "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path[srpolicy:name = current()]/srpolicy:hop-type = 'ipv6'";
                }
              }
              uses disjoint-association-group;
              uses policy-association-group;
            }
          }
        }
      }
    }
  }

  grouping odn-templates {
    description
      "Grouping containing ODN templates.";
    container odn-templates {
      description
        "List of SR Policy ODN templates.";
      list odn-template {
        key "color";
        description
          "Configure an SR Policy ODN template.";
        leaf color {
          type uint32 {
            range "1..4294967295";
          }
          description
            "ODN color.";
        }
        container compute-types {
          description
            "List of different types of computation sources.";
          list compute-type {
            key "type";
            ordered-by user;
            description
              "Configure a computation source type.";
            leaf type {
              type global-compute-type;
              description
                "Computation source type.";
            }
          }
        }
        leaf constraint-template-name {
          type leafref {
            path "/srpolicy:srpolicy/srpolicy:constraint-templates/srpolicy:constraint-template/srpolicy:name";
          }
          description
            "Name of a constraint template.";
        }
        leaf attribute-template-id {
          type leafref {
            path "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template/srpolicy:id";
          }
          must "((/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-bypass = 'not-configured') and (/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-enable = 'not-configured' or /srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-enable = 'sbfd-enable' or /srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-enable = 'disable') and (/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:path-verification-enable = 'not-configured') and not(/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-slice-inherit-match))";
          must "not(/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:path-mtu-detect)";
          description
            "Attribute template ID.";
        }
        leaf restrict-ip-prefix {
          type leafref {
            path "/rtp:routing-policy/rtp:ipv4-prefix-filters/rtp:ipv4-prefix-filter/rtp:name";
          }
          description
            "Specify the IPv4 filtering policy applied to the ODN template. By default, no such policy is specified.";
        }
        container candidate-paths {
          description
            "List of candidate paths in an ODN template.";
          list candidate-path {
            key "preference";
            max-elements 64;
            description
              "Configure a candidate path.";
            leaf preference {
              type uint32 {
                range "1..65535";
              }
              description
                "Candidate path preference.";
            }
            uses constraints {
              refine "constraint-path-name" {
                must "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path[srpolicy:name = current()]/srpolicy:hop-type = 'ipv4'";
              }
            }
            uses disjoint-association-group;
            uses policy-association-group;
          }
        }
      }
    }
  }

  grouping srv4-policy-attributes {
    description
      "Grouping containing attributes applicable to all SR policies.";
    container policy-attributes {
      description
        "Configure attributes for all SR policies.";
      uses global-attributes;
      uses srv4-segment-lists;
      uses odn-templates;
      container policy-association-groups {
        description
          "List of policy association groups.";
        list policy-association-group {
          key "group-id source-ip";
          description
            "Configure a policy association group.";
          leaf group-id {
            type uint16 {
              range "1..65534";
            }
            description
              "ID of a policy association group.";
          }
          leaf source-ip {
            type inet:ip-address;
            description
              "Source IP address of a policy association group.";
          }
          leaf attribute-template-id {
            type leafref {
              path "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template/srpolicy:id";
            }
            must "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-bypass = 'not-configured'";
            must "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-enable = 'not-configured' or /srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-enable = 'sbfd-enable' or /srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-enable = 'disable'";
            must "not(/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:bfd-slice-inherit-match)";
            must "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:path-verification-enable = 'not-configured'";
            must "not(/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template[srpolicy:id=current()]/srpolicy:path-mtu-detect)";
            description
              "Attribute template ID.";
          }
        }
      }
    }
  }

  grouping srv4-policys {
    description
      "SR policy grouping.";
    container policys {
      description
        "List of SR Policies.";
      list policy {
        key "endpoint color";
        unique "name";
        unique "binding-sid/value";
        description
          "Configure an SR Policy.";
        leaf endpoint {
          type inet:ip-address;
          description
            "SR Policy endpoint address.";
        }
        leaf color {
          type uint32 {
            range "0..4294967295";
          }
          description
            "SR Policy color.";
        }
        leaf name {
          type string {
            length "1..127";
          }
          mandatory true;
          description
            "SR Policy name.";
        }
        leaf metric-inherit-igp {
          type boolean;
          default "false";
          description
            "Enable/disable IGP cost inheritance.";
        }
        choice metric-type {
          description
            "IGP metric type. The absolute type is supported.";
          case absolute {
            description
              "Absolute type.";
            leaf absolute {
              type int32 {
                range "1..65535";
              }
              description
                "Cost of the IGP metric of the absolute type.";
            }
          }
        }
        container binding-sid {
          description
            "Configure a binding SID.";
          leaf dataplane {
            type dataplane-type;
            must "(../dataplane='mpls')";
            description
              "Binding sid dataplane type.";
          }
          leaf value {
            when "(../dataplane='mpls')";
            type sid-value-type;
            mandatory true;
            description
              "Binding sid value.";
          }
        }
        leaf admin-state {
          type admin-state-type;
          default "up";
          description
            "Close the function of SR Policy.";
        }
        leaf mtu {
          type uint32 {
            range "512..9600";
          }
          description
            "SR Policy mtu value.";
        }
        leaf hsb-enable {
          type enable-3types;
          default "not-configured";
          description
            "SR Policy hot standby.";
        }
        leaf bfd-enable {
          type policy-bfd-enable-type;
          default "not-configured";
          description
            "SR Policy BFD.";
        }
        container bfd-address {
          description
            "Configure the source addresses and destination addresses for BFD sessions.";
          choice source {
            description
              "Configure the SBFD source address.";
            case address {
              description
                "Source address of the BFD session.";
              leaf source-address {
                type inet:ip-address;
                description
                  "Source address of the BFD session.";
              }
            }
            case interface {
              description
                "Source interface mode.";
              leaf source-interface {
                type leafref {
                  path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
                }
                must "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name=current()]/ifm:type='LoopBack'";
                description
                  "Source interface of the BFD session.";
              }
            }
          }
          leaf destination-address {
            type inet:ip-address;
            description
              "Destination address of the BFD session.";
          }
        }
        leaf traffic-statistics-enable {
          type enable-3types;
          default "not-configured";
          description
            "SR Policy traffic statistics.";
        }
        container diffserv-mode {
          description
            "Configure the DiffServ mode in an SR Policy.";
          leaf pipe-mode {
            type pipe-mode-type;
            description
              "Specifies the pipe mode of SR Policy.";
          }
          leaf service-class {
            when "../pipe-mode='pipe'";
            type serv-class-types;
            mandatory true;
            description
              "Service class of SR Policy.";
          }
          leaf service-color {
            when "../pipe-mode='pipe'";
            type serv-color-types;
            mandatory true;
            description
              "Service color of SR Policy.";
          }
        }
        leaf constraint-template-name {
          type leafref {
            path "/srpolicy:srpolicy/srpolicy:constraint-templates/srpolicy:constraint-template/srpolicy:name";
          }
          description
            "Name of a constraint template.";
        }
        leaf bfd-min-tx {
          type uint32 {
            range "1..4294967295";
          }
          units "ms";
          description
            "Minimum interval for sending seamless-bfd packets to the peer end over the candidate path.";
        }
        leaf bfd-multi-num {
          type uint32 {
            range "3..50";
          }
          description
            "Local detection multiplier over the candidate path.";
        }
        leaf bfd-backup-min-tx {
          type uint32 {
            range "1..4294967295";
          }
          units "ms";
          description
            "Minimum interval for sending seamless-bfd packets to the peer end over the backup candidate path.";
        }
        leaf bfd-backup-multi-num {
          type uint32 {
            range "3..50";
          }
          description
            "Local detection multiplier over the backup candidate path.";
        }
        container compute-types {
          description
            "List of different types of computation sources.";
          list compute-type {
            key "type";
            ordered-by user;
            description
              "Configure a computation source type for an SR policy.";
            leaf type {
              type policy-compute-type;
              must "../type = 'none' and count(../../compute-type/type[.!=current()]) < 1 or ../type != 'none'";
              description
                "Computation source type.";
            }
          }
        }
        uses auto-bandwidth-adjustment;
        container candidate-paths {
          description
            "List of candidate paths in an SR Policy.";
          list candidate-path {
            must "(discriminator=preference)";
            key "protocol-origin originator discriminator";
            max-elements 64;
            description
              "Configure a candidate path.";
            leaf protocol-origin {
              type protocol-origin-type;
              must "(../protocol-origin='configuration')";
              description
                "Candidate path protocol origin.";
            }
            leaf originator {
              type string {
                length "1..60";
              }
              must "(../originator='0,0.0.0.0')";
              description
                "Candidate path originator.";
            }
            leaf discriminator {
              type uint32 {
                range "1..65535";
              }
              description
                "Candidate path discriminator.";
            }
            leaf preference {
              type uint32 {
                range "1..65535";
              }
              mandatory true;
              description
                "Candidate path preference.";
            }
            choice type {
              description
                "Type of candidate paths.";
              case explicit {
                description
                  "Candidate path with explicitly defined set/s of segment-lists.";
                container segment-lists {
                  description
                    "List of segment lists in a candidate path.";
                  list segment-list {
                    key "name";
                    max-elements 64;
                    description
                      "Configure a segment list for a candidate path.";
                    leaf name {
                      type leafref {
                        path "../../../../../../../policy-attributes/segment-lists/segment-list/name";
                      }
                      description
                        "Segment list name.";
                    }
                    leaf weight {
                      type uint32 {
                       
                        range "0..4294967295";
                      }
                      default "1";
                      description
                        "Segment-list weighted loadshare.";
                    }
                    leaf path-mtu {
                      type uint32 {
                        range "1280..9600";
                      }
                      description
                        "Segment-list path-mtu.";
                    }
                    container binding-sids {
                      description
                        "List of a segment list's binding SIDs.";
                      list binding-sid {
                        key "dataplane value";
                        max-elements 1;
                        description
                          "Configure a binding SID.";
                        leaf dataplane {
                          type dataplane-type;
                          must "(../dataplane='mpls')";
                          description
                            "Binding SID dataplane type.";
                        }
                        leaf value {
                          type sid-value-type;
                          description
                            "Binding SID value.";
                        }
                      }
                    }
                    container reverse-binding-sid {
                      description
                        "Configure a reverse binding SID for a segment list.";
                      leaf dataplane {
                        type dataplane-type;
                        must "(../dataplane='mpls')";
                        description
                          "Reverse binding SID dataplane type.";
                      }
                      leaf value {
                        when "(../dataplane='mpls')";
                        type sid-value-type;
                        mandatory true;
                        description
                          "Reverse binding SID value of a segment list.";
                      }
                    }
                    choice bfd-source {
                      description
                        "Configure the SBFD source address.";
                      case address {
                        description
                          "Source address of the BFD session.";
                        leaf bfd-source-address {
                          type inet:ip-address;
                          description
                            "Source address of the BFD session.";
                        }
                      }
                      case interface {
                        description
                          "Source interface mode.";
                        leaf bfd-source-interface {
                          type leafref {
                            path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
                          }
                          must "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name=current()]/ifm:type='LoopBack'";
                          description
                            "Source interface of the BFD session.";
                        }
                      }
                    }
                    leaf bfd-destination-address {
                      type inet:ip-address;
                      description
                        "Destination address of the BFD session.";
                    }
                  }
                }
              }
              case dynamic {
                description
                  "Candidate path with an optimization objective and a set of constraints.";
                container constraints {
                  presence "Create a set of constraints.";
                  description
                    "Configure a set of constraints contained in a dynamic candidate path.";
                  uses constraints {
                    refine "constraint-path-name" {
                      must "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path[srpolicy:name = current()]/srpolicy:hop-type = 'ipv4'";
                    }
                  }
                  uses disjoint-association-group;
                  uses policy-association-group;
                  uses bidirectional-association-group;
                }
              }
            }
            leaf template-id {
              type leafref {
                path "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template/srpolicy:id";
              }
              description
                "Attribute template ID.";
            }
            leaf network-slice-id {
              type uint32 {
                range "1..4294967295";
              }
              description
                "Network slice ID of a candidate path.";
            }
          }
        }
      }
    }
  }

  grouping segment-list-constraint-path-group {
    description
      "Segment list-specific path constraint grouping.";
    container segment-list-constraint-paths {
      description
        "List of segment list-specific path constraints.";
      list segment-list-constraint-path {
        key "constraint-path-name";
        max-elements 8;
        description
          "Configure a segment list-specific path constraint.";
        leaf constraint-path-name {
          type leafref {
            path "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path/srpolicy:name";
          }
          must "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path[srpolicy:name = current()]/srpolicy:hop-type = 'ipv6'";
          description
            "Path constraint name.";
        }
      }
    }
  }

  grouping srv6-policys {
    description
      "SR policy grouping.";
    container policys {
      description
        "List of SR Policies.";
      list policy {
        key "endpoint color";
        unique "name";
        description
          "Configure an SR Policy.";
        leaf endpoint {
          type inet:ip-address;
          description
            "SR Policy endpoint address.";
        }
        leaf color {
          type uint32 {
            range "0..4294967295";
          }
          description
            "SR Policy color.";
        }
        leaf name {
          type string {
            length "1..127";
          }
          mandatory true;
          description
            "SR Policy name.";
        }
        leaf locator {
         
          type leafref {
            path "/ni:network-instance/ni:instances/ni:instance/srv6:srv6/srv6:locators/srv6:locator/srv6:name";
          }
          description
            "Locator Name.";
        }
        container binding-sid {
         
          must "not(../binding-sid/value) or (../binding-sid/value and count(../../../policy-attributes/locators/locator)>0)";
          status deprecated;
          description
            "Configure a binding SID. The node binding-sid is deprecated. You are advised to use the node binding-sids.";
          leaf dataplane {
            type dataplane-type;
            must "(../dataplane='srv6')";
            status deprecated;
            description
              "Binding sid dataplane type.";
          }
          leaf value {
            when "(../dataplane='srv6')";
            type sid-value-type;
            mandatory true;
            status deprecated;
            description
              "Binding sid value.";
          }
        }
        container binding-sids {
          description
            "List of SR Policy binding SIDs.";
          list binding-sid {
            must "count(../../../../policy-attributes/locators/locator)>0";
            key "dataplane value";
            max-elements 2;
            description
              "Configure a binding SID.";
            leaf dataplane {
              type dataplane-type;
              must "(../dataplane='srv6')";
              description
                "Binding sid dataplane type.";
            }
            leaf value {
              type sid-value-type;
              description
                "Binding sid value.";
            }
          }
        }
        leaf admin-state {
          type admin-state-type;
          default "up";
          description
            "Close the function of SR Policy.";
        }
        leaf mtu {
          type uint32 {
            range "1280..9600";
          }
          description
            "SRv6 TE Policy MTU value.";
        }
        leaf hsb-enable {
          type enable-3types;
          default "not-configured";
          description
            "SR Policy hot standby.";
        }
        leaf bfd-enable {
          type policy-bfd-enable-type;
          must "((../bfd-enable='not-configured') or (../bfd-enable='disable') or (../bfd-enable='ubfd-enable')) and (../endpoint='::') or (../endpoint!='::')";
          default "not-configured";
          description
            "SR Policy BFD.";
        }
        leaf bfd-bypass {
          type policy-bfd-bypass-type;
          default "not-configured";
          description
            "SR policy BFD bypass.";
        }
        leaf bfd-min-tx {
          type uint32 {
            range "1..4294967295";
          }
          units "ms";
          description
            "Minimum interval for sending BFD packets to the peer end.";
        }
        leaf bfd-multi-num {
          type uint32 {
            range "3..50";
          }
          description
            "Local detection multiplier.";
        }
        leaf bfd-backup-min-tx {
          type uint32 {
            range "1..4294967295";
          }
          units "ms";
          description
            "Minimum interval for sending BFD packets to the peer end over the backup candidate path.";
        }
        leaf bfd-backup-multi-num {
          type uint32 {
            range "3..50";
          }
          description
            "Local detection multiplier over the backup candidate path.";
        }
        container bfd-address {
          presence "Configure bfd-address.";
          description
            "Configure the source addresses and destination addresses for BFD packets.";
          leaf source-address {
            type inet:ip-address;
            mandatory true;
            description
              "Source address of the BFD session.";
          }
          leaf destination-address {
            type inet:ip-address;
            description
              "Destination address of the BFD session.";
          }
        }
        leaf traffic-statistics-enable {
          type enable-3types;
          default "not-configured";
          description
            "SR Policy traffic statistics.";
        }
        leaf path-mtu-detect {
          when "(../endpoint!='::')";
          type path-mtu-detect-type;
          description
            "SR Policy path MTU detection.";
        }
        leaf path-verification {
          type path-verification-type;
          default "not-configured";
          description
            "SR Policy path verification.";
        }
        leaf encapsulation-mode {
          type encapsulation-cfg-type;
          description
            "SR Policy encapsulation mode.";
        }
        leaf forward-no-bypass {
          type policy-fwd-no-bypass-type;
          description
            "Traffic is not forwarded over the local protection path.";
        }
        container diffserv-mode {
          description
            "Configure the DiffServ mode in an SR Policy.";
          leaf pipe-mode {
            type pipe-mode-type;
            description
              "Specifies the pipe mode of SR Policy.";
          }
          leaf service-class {
            when "../pipe-mode='pipe'";
            type serv-class-types;
            mandatory true;
            description
              "Service class of SR Policy.";
          }
          leaf service-color {
            when "../pipe-mode='pipe'";
            type serv-color-types;
            mandatory true;
            description
              "Service color of SR Policy.";
          }
        }
        leaf ifit-delay-enable {
          when "(../endpoint!='::')";
          type enable-type;
          default "disable";
          description
            "SR Policy IFIT delay enabling.";
        }
        leaf ifit-loss-rate-enable {
          when "(../endpoint!='::')";
          type enable-type;
          default "disable";
          description
            "SR Policy IFIT loss-rate enabling.";
        }
        leaf ifit-interval {
          when "(../endpoint!='::')";
          type uint32 {
            range "2|10|30|60|300";
          }
          units "s";
          default "30";
          description
            "SR Policy IFIT interval.";
        }
        leaf ifit-measure-mode {
          when "(../endpoint!='::')";
          type ifit-measure-mode-type;
          default "e2e";
          description
            "SR Policy IFIT measure mode.";
        }
        leaf shortcut-type {
          when "(../endpoint!='::')";
          type shortcut-mode;
          default "disable";
          description
            "SR Policy shortcut type.";
        }
        leaf route-policy-name {
          when "(../shortcut-type='isis') and (../endpoint!='::')";
          type leafref {
            path "/rtp:routing-policy/rtp:policy-definitions/rtp:policy-definition/rtp:name";
          }
          description
            "Route policy name.";
        }
        choice metric-type {
          default "relative";
          description
            "IGP metric type. The absolute type is supported.";
          case absolute {
            description
              "Absolute type.";
            leaf absolute {
              type int32 {
                range "1..65535";
              }
              description
                "Cost of the IGP metric of the absolute type.";
            }
          }
          case relative {
            description
              "Relative type.";
            leaf relative {
              when "(../endpoint!='::')";
              type int32 {
                range "-10..10";
              }
              default "-1";
              description
                "Cost of the IGP metric of the relative type.";
            }
          }
        }
        leaf process-id {
          when "(../shortcut-type='isis') and (../endpoint!='::')";
          type leafref {
            path "/ni:network-instance/ni:instances/ni:instance/isis:isis/isis:sites/isis:site/isis:id";
          }
          must "/ni:network-instance/ni:instances/ni:instance/isis:isis/isis:sites/isis:site[isis:id=current()]/isis:afs/isis:af[isis:type='afipv6']";
          description
            "ISIS process id.";
        }
        leaf bfd-slice-inherit-match {
          type bfd-slice-inherit-match-type;
          description
            "Inheritance type (for the network slice's match mode) of BFD detection packets configured for the SRv6 TE Policy.";
        }
        leaf metric-inherit-type {
          type metric-inherit-mode;
          description
            "Metric type inherited by SRv6 TE Policy.";
        }
        leaf constraint-template-name {
          type leafref {
            path "/srpolicy:srpolicy/srpolicy:constraint-templates/srpolicy:constraint-template/srpolicy:name";
          }
          must "(../endpoint != '::') and (../color != 0)";
          description
            "Name of a constraint template.";
        }
        leaf segment-list-delete-hold {
          type delete-hold-type;
          description
            "Hold the deleted segment lists when new segment lists all down.";
        }
        container metric-values {
          description
            "List of metric values configured for SRv6 TE Policy.";
          list metric-value {
            key "type";
            description
              "Configure a metric value.";
            leaf type {
              type metric-value-type;
              description
                "Metric value type.";
            }
            choice value {
              mandatory true;
              description
                "SRv6 TE Policy metric value.";
              case absolute {
                description
                  "Absolute value type.";
                leaf absolute {
                  type uint32 {
                    range "1..4261412863";
                  }
                  description
                    "Absolute metric value.";
                }
              }
            }
          }
        }
        container compute-types {
          description
            "List of different types of computation sources.";
          list compute-type {
            must "(../../endpoint != '::') and (../../color != 0)";
            key "type";
            ordered-by user;
            description
              "Configure a computation source type for an SRv6 TE policy.";
            leaf type {
              type policy-compute-type;
              must "../type = 'none' and count(../../compute-type/type[.!=current()]) < 1 or ../type != 'none'";
              description
                "Computation source type.";
            }
          }
        }
        leaf reduce {
          type enable-type;
          description
            "Enable/Disable the Reduce function for an SRv6 TE Policy.";
        }
        leaf bsid-endpoint-behavior {
          type bsid-endpoint-behavior-type;
          description
            "Endpoint behavior of binding SIDs.";
        }
        leaf afr {
          type afr-type;
          description
            "Adaptive flow repathing.";
        }
        leaf dual-fed {
          type dual-fed-type;
          description
            "Enable/Disable the dual-fed function for an SRv6 TE Policy.";
        }
        container candidate-paths {
          description
            "List of candidate paths in an SR Policy.";
          list candidate-path {
            must "(discriminator=preference)";
            key "protocol-origin originator discriminator";
            max-elements 64;
            description
              "Configure a candidate path.";
            leaf protocol-origin {
              type protocol-origin-type;
              must "(../protocol-origin='configuration')";
              description
                "Candidate path protocol origin.";
            }
            leaf originator {
              type string {
                length "1..60";
              }
              must "(../originator='0,0.0.0.0')";
              description
                "Candidate path originator.";
            }
            leaf discriminator {
              type uint32 {
                range "1..65535";
              }
              description
                "Candidate path discriminator.";
            }
            leaf preference {
              type uint32 {
                range "1..65535";
              }
              mandatory true;
              description
                "Candidate path preference.";
            }
            choice type {
              description
                "Type of candidate paths.";
              case explicit {
                description
                  "Candidate path with explicitly defined set/s of segment-lists.";
                container segment-lists {
                  description
                    "List of segment lists in a candidate path.";
                  list segment-list {
                    key "name";
                    max-elements 64;
                    description
                      "Configure a segment list for a candidate path.";
                    leaf name {
                      type leafref {
                        path "../../../../../../../policy-attributes/segment-lists/segment-list/name";
                      }
                      description
                        "Segment list name.";
                    }
                    choice co-routed-path-type {
                      description
                        "Type of co-routed path.";
                      case bsid {
                        description
                          "Binding SIDs.";
                        container binding-sid {
                         
                          must "not(../binding-sid/value) or (../binding-sid/value and count(../../../../../../../policy-attributes/locators/locator)>0)";
                          status deprecated;
                          description
                            "Configure a binding SID. The node binding-sid is deprecated. You are advised to use the node binding-sids.";
                          leaf dataplane {
                            type dataplane-type;
                            must "(../dataplane='srv6')";
                            status deprecated;
                            description
                              "Binding SID dataplane type.";
                          }
                          leaf value {
                            when "(../dataplane='srv6')";
                            type sid-value-type;
                            mandatory true;
                            status deprecated;
                            description
                              "Binding SID value of segment list.";
                          }
                        }
                        container binding-sids {
                          description
                            "List of segment list binding SIDs.";
                          list binding-sid {
                            must "count(../../../../../../../../policy-attributes/locators/locator)>0";
                            key "dataplane value";
                            max-elements 2;
                            description
                              "Configure a binding SID.";
                            leaf dataplane {
                              type dataplane-type;
                              must "(../dataplane='srv6')";
                              description
                                "Binding sid dataplane type.";
                            }
                            leaf value {
                              type sid-value-type;
                              description
                                "Binding sid value.";
                            }
                          }
                        }
                        container reverse-binding-sid {
                          description
                            "Configure a reverse binding SID of segment list.";
                          leaf dataplane {
                            type dataplane-type;
                            must "(../dataplane='srv6')";
                            description
                              "Reverse binding SID dataplane type.";
                          }
                          leaf value {
                            when "(../dataplane='srv6')";
                            type sid-value-type;
                            mandatory true;
                            description
                              "Reverse binding SID value of segment list.";
                          }
                        }
                      }
                      case xsid {
                        description
                          "XSIDs.";
                        container xsids {
                          description
                            "List of segment list XSIDs.";
                          list xsid {
                            must "count(../../../../../../../../policy-attributes/locators/locator)>0";
                            key "dataplane value";
                            max-elements 2;
                            description
                              "Configure an XSID.";
                            leaf dataplane {
                              type dataplane-type;
                              must "(../dataplane='srv6')";
                              description
                                "XSID data plane type.";
                            }
                            leaf value {
                              type sid-value-type;
                              description
                                "XSID value.";
                            }
                            leaf encapsulation-mode {
                              type xsid-encapsulation-type;
                              mandatory true;
                              description
                                "XSID encapsulation mode.";
                            }
                          }
                        }
                        container reverse-xsid {
                          description
                            "Configure a reverse XSID in a segment list.";
                          leaf dataplane {
                            type dataplane-type;
                            must "(../dataplane='srv6')";
                            description
                              "Reverse XSID data plane type.";
                          }
                          leaf value {
                            when "(../dataplane='srv6')";
                            type sid-value-type;
                            mandatory true;
                            description
                              "Reverse XSID value in a segment list.";
                          }
                        }
                      }
                    }
                    leaf weight {
                      type uint32 {
                       
                        range "0..4294967295";
                      }
                      default "1";
                      description
                        "Segment-list weighted loadshare.";
                    }
                    leaf path-mtu {
                      type uint32 {
                        range "1280..9600";
                      }
                      description
                        "Segment-list path-mtu.";
                    }
                  }
                }
              }
              case dynamic {
                description
                  "Candidate path with an optimization objective and a set of constraints.";
                container constraints {
                  must "not (../template-id)";
                  must "(../../../endpoint != '::') and (../../../color != 0)";
                  presence "Create a set of constraints.";
                  description
                    "Configure a set of constraints contained in a dynamic candidate path.";
                  uses constraints {
                    refine "constraint-path-name" {
                      must "/srpolicy:srpolicy/srpolicy:constraint-paths/srpolicy:constraint-path[srpolicy:name = current()]/srpolicy:hop-type = 'ipv6'";
                    }
                  }
                  uses disjoint-association-group;
                  uses policy-association-group;
                  uses segment-list-constraint-path-group;
                }
              }
            }
            leaf template-id {
              type leafref {
                path "/srpolicy:srpolicy/srpolicy:attribute-templates/srpolicy:attribute-template/srpolicy:id";
              }
              description
                "Attribute template ID.";
            }
            leaf network-slice-id {
              type uint32 {
                range "1..4294967295";
              }
              description
                "Network slice ID of a candidate path.";
            }
          }
        }
      }
    }
  }

  grouping policy-groups {
    description
      "SR-MPLS TE Policy group grouping.";
    container policy-groups {
      description
        "List of SR-MPLS TE Policy groups.";
      list policy-group {
        key "index";
        description
          "Configure an SR-MPLS TE Policy group.";
        leaf index {
          type uint32 {
            range "1..4294967295";
          }
          description
            "SR-MPLS TE Policy group id.";
        }
        leaf endpoint {
          type inet:ip-address;
          description
            "SR-MPLS TE Policy IPv4 endPoint address.";
        }
        leaf description {
          type string {
            length "1..242";
          }
          description
            "SR-MPLS TE Policy group description.";
        }
        leaf match-type {
          type group-match-type;
          must "(../match-type='service-class') or (../match-type='dscp')";
          default "dscp";
          description
            "Match type of an SR-MPLS TE Policy group.";
        }
        leaf state {
          type state-type;
          config false;
          description
            "SR-MPLS TE Policy group state.";
        }
        leaf delay-timer-remain {
          type uint32;
          units "ms";
          config false;
          description
            "Remaining delay.";
        }
        leaf state-change-time {
          type yang:date-and-time;
          config false;
          description
            "Date and time when the state of a group changed.";
        }
        leaf tunnel-id {
          type uint32;
          config false;
          description
            "SR-MPLS TE Policy group tunnel id.";
        }
        leaf tunnel-type {
          type tunnel-type;
          config false;
          description
            "SR-MPLS TE Policy group tunnel type.";
        }
        leaf match-count {
          type uint32;
          config false;
          description
            "SR-MPLS TE Policy group match count.";
        }
        leaf up-match-count {
          type uint32;
          config false;
          description
            "SR-MPLS TE Policy group up match count.";
        }
        container color-dscp-matchs {
          when "contains(../match-type, 'dscp')";
          description
            "List of color-address family-DSCP mappings for an SR-MPLS TE Policy.";
          list color-dscp-match {
            key "color af-type";
            max-elements 128;
            description
              "Configure a color-address family-DSCP mapping for an SR-MPLS TE Policy.";
            leaf color {
              type uint32 {
                range "0..4294967295";
              }
              description
                "SR-MPLS TE Policy color.";
            }
            leaf af-type {
              type address-family-type;
              description
                "Address family.";
            }
            leaf default {
              type boolean;
              default "false";
              description
                "Enable/disable the default SR-MPLS TE Policy.";
            }
            leaf dscp-value {
              when "not(../default='true')";
              type pub-type:id-range {
               
              }
              mandatory true;
              description
                "DSCP Value.";
            }
            leaf policy-tunnel-id {
              type uint32;
              config false;
              description
                "SR-MPLS TE Policy tunnel ID.";
            }
            leaf state {
              type state-type;
              config false;
              description
                "SR-MPLS TE Policy group mapping state.";
            }
          }
        }
        container service-class-maps {
          when "contains(../match-type, 'service-class')";
          description
            "List of Service Class-based mappings.";
          list service-class-map {
            key "index";
            description
              "Configure a Service Class-based mapping.";
            leaf index {
              type uint32 {
                range "1..4294967295";
              }
              description
                "Index.";
            }
            leaf service-class {
              when "../index != 4294967295";
              type service-class-type;
              mandatory true;
              description
                "Service Class type.";
            }
            choice match-tunnel {
              mandatory true;
              description
                "Match tunnel.";
              case sr-policy {
                description
                  "Flow match SR Policy.";
                leaf color {
                  type uint32 {
                    range "1..4294967295";
                  }
                  must "not(../../service-class-map[color=current()][index!=current()/../index])";
                  description
                    "Color of an SR Policy.";
                }
              }
            }
            leaf policy-tunnel-id {
              type uint32;
              config false;
              description
                "SR-MPLS TE Policy tunnel ID.";
            }
            leaf state {
              type state-type;
              config false;
              description
                "Mapping state of an SR-MPLS TE Policy group.";
            }
          }
        }
      }
    }
  }

  grouping srv6-policy-infos {
    description
      "SRv6 Policy infos grouping.";
    container policy-infos {
      config false;
      description
        "List of SRv6 TE Policies.";
      list policy-info {
        key "endpoint color";
        description
          "Operational state of an SRv6 TE Policy.";
        leaf endpoint {
          type inet:ipv6-address-no-zone;
          description
            "SR Policy endpoint address.";
        }
        leaf color {
          type uint32;
          description
            "SR Policy color.";
        }
        leaf name {
         
          type string {
            length "1..255";
          }
          description
            "SR Policy name.";
        }
        leaf state {
          type string {
            length "1..31";
          }
          description
            "SR Policy states.";
        }
        leaf state-change-time {
          type yang:date-and-time;
          description
            "SR Policy state change time.";
        }
        leaf admin-state {
          type admin-state-type;
          description
            "SR Policy admin states.";
        }
        leaf binding-sid {
         
          type inet:ipv6-address-no-zone;
          description
            "SR Policy preferred binding SID.";
        }
        leaf bsid-encapsulation-mode {
          type encapsulation-disp-type;
          description
            "SR Policy binding SID encapsulation mode.";
        }
        container binding-sids {
          description
            "List of SR Policy's binding SIDs.";
          list binding-sid {
            key "sid-value";
            max-elements 2;
            description
              "Operational data of an SR Policy's binding SID.";
            leaf sid-value {
              type inet:ipv6-address-no-zone;
              description
                "Binding SID value.";
            }
            leaf encapsulation-mode {
              type encapsulation-disp-type;
              description
                "Binding SID encapsulation mode.";
            }
            leaf reduce {
              type enable-type;
              description
                "Whether the Reduce function is enabled for a binding SID.";
            }
          }
        }
        leaf tunnel-id {
          type uint32;
          description
            "SR Policy tunnel ID.";
        }
        leaf tunnel-type {
          type tunnel-type;
          description
            "SR Policy tunnel type.";
        }
        leaf bfd-enable {
          type bfd-enable-type;
          description
            "SR Policy BFD enable flag.";
        }
        leaf bfd-bypass {
          type bfd-bypass-type;
          description
            "SR policy BFD bypass enable flag.";
        }
        leaf bfd-slice-inherit-match {
          type bfd-slice-inherit-match-disp-type;
          description
            "Display the active inheritance type for the SRv6 TE Policy.";
        }
        leaf hsb-enable {
          type enable-type;
          description
            "SR Policy HSB enable flag.";
        }
        leaf encapsulation-mode {
          type encapsulation-disp-type;
          description
            "SR Policy encapsulation mode.";
        }
        leaf traffic-statistics-enable {
          type enable-type;
          description
            "SR Policy traffic statistics enable flag.";
        }
        leaf ifit-loss-rate-enable {
          type enable-type;
          description
            "SR Policy IFIT loss-rate enable flag.";
        }
        leaf ifit-delay-enable {
          type enable-type;
          description
            "SR Policy IFIT delay enable flag.";
        }
        leaf ifit-interval {
          type uint32;
          units "s";
          description
            "SR Policy IFIT interval.";
        }
        leaf ifit-measure-mode {
          type ifit-measure-mode-type;
          description
            "SR Policy IFIT measure mode.";
        }
        leaf ifit-one-way-delay {
          type uint32;
          units "ms";
          description
