  }

  deviation "/if:interfaces/if:interface/bbf-pppoe-ia:pppoe/bbf-pppoe-ia:profile-ref" {
    deviate not-supported;
  }
  deviation "/bbf-pppoe-ia:pppoe-profiles" {
