{
  "name": "@exergy-connect/xyang",
  "version": "0.1.2",
  "description": "TypeScript xYang bridge and compatibility surface",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exergy-connect/xYang.git",
    "directory": "ts"
  },
  "bugs": {
    "url": "https://github.com/exergy-connect/xYang/issues"
  },
  "homepage": "https://github.com/exergy-connect/xYang#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.umd.min.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./encoding": {
      "types": "./dist/encoding-entry.d.ts",
      "import": "./dist/encoding-entry.js",
      "default": "./dist/encoding-entry.js"
    },
    "./types": {
      "types": "./dist/types-entry.d.ts",
      "import": "./dist/types-entry.js",
      "default": "./dist/types-entry.js"
    }
  },
  "bin": {
    "xyang-ts": "dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup && node ./scripts/build-browser-iife.mjs",
    "build:check": "npm run build && node ./scripts/check-artifacts.mjs && node ./scripts/sync-docs-browser-bundle.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
